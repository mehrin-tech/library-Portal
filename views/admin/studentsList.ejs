<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Students Registry | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary-teal: #008080;
    }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
    .focus-ring-teal:focus { 
      --tw-ring-color: var(--primary-teal); 
      border-color: var(--primary-teal); 
    }
  </style>
</head>

<body class="bg-slate-50 min-h-screen font-sans text-slate-900">

<%- include('../partials/adminSidebar')%>

<main class="ml-0 md:ml-20 p-3 md:p-8">

  <div class="max-w-7xl mx-auto bg-white shadow-2xl rounded-2xl md:rounded-[2.5rem] overflow-hidden border">

    <!-- HEADER -->
    <div class="px-4 md:px-8 py-4 md:py-8 border-b flex flex-col lg:flex-row justify-between gap-4">

      <h2 class="text-xl md:text-3xl font-black">
        Student <span class="text-teal-600">Records</span>
      </h2>

      <div class="w-full sm:w-auto">
        <input
          type="text"
          id="searchInp"
          placeholder="Search..."
          class="w-full sm:w-64 pl-4 pr-4 py-2 bg-slate-50 border rounded-xl text-sm focus:ring-2 focus:ring-teal-500"
        />
      </div>

    </div>

    <!-- TABLE -->
    <div class="overflow-x-auto">
      <table class="w-full text-xs md:text-sm">

        <thead class="bg-slate-50">
          <tr>
            <th class="px-3 md:px-6 py-3 text-left">ID</th>
            <th class="px-3 md:px-6 py-3 text-left">Name</th>
            <th class="px-3 md:px-6 py-3 text-left">Dept</th>
            <th class="px-3 md:px-6 py-3 text-left">Sem</th>
            <th class="px-3 md:px-6 py-3 text-left">Status</th>
          </tr>
        </thead>

        <tbody>
          <% users.forEach((user,i) => { %>

          <tr class="student-row hover:bg-teal-50">

            <td class="px-3 md:px-6 py-3 text-xs">
              #<%=(currentPage-1)*limit+i+1 %>
            </td>

            <td class="px-3 md:px-6 py-3 font-bold student-name">
              <%= user.username %>
            </td>

            <td class="px-3 md:px-6 py-3 text-xs">
              <%= user.department || 'N/A' %>
            </td>

            <td class="px-3 md:px-6 py-3 text-xs">
              <%= user.semester || '-' %>
            </td>

            <td class="px-3 md:px-6 py-3">
              <span class="text-xs px-2 py-1 rounded-full
                <%= user.status==='Active' ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600' %>">
                <%= user.status %>
              </span>
            </td>

          </tr>

          <% }) %>
        </tbody>

      </table>
    </div>

  </div>

  <!-- PAGINATION -->
  <div class="flex flex-wrap justify-center gap-2 py-6">

    <% if(currentPage>1){ %>
      <a href="?page=<%=currentPage-1%>" class="px-3 py-1 bg-slate-100 rounded">Prev</a>
    <% } %>

    <% for(let i=1;i<=totalPages;i++){ %>
      <a href="?page=<%=i%>" class="px-3 py-1 rounded
      <%= i===currentPage ? 'bg-teal-600 text-white' : 'bg-slate-100' %>">
      <%=i%></a>
    <% } %>

    <% if(currentPage<totalPages){ %>
      <a href="?page=<%=currentPage+1%>" class="px-3 py-1 bg-slate-100 rounded">Next</a>
    <% } %>

  </div>

</main>

  <script>
    const searchInp = document.getElementById('searchInp');
    const rows = document.querySelectorAll('.student-row');

    searchInp.addEventListener('keyup', function () {
      const val = searchInp.value.toLowerCase().trim();
      rows.forEach(row => {
        const name = row.querySelector('.student-name').textContent.toLowerCase();
        row.style.display = name.includes(val) ? '' : 'none';
      });
    });
  </script>

</body>
</html>