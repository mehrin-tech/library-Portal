<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Add Book | Library System</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-50 min-h-screen flex items-center justify-center p-4 font-sans overflow-hidden">

<div class="bg-white shadow-xl rounded-3xl p-6 w-full max-w-md border border-slate-100 overflow-hidden">

<div class="text-center mb-4">
<h1 class="text-xl font-black text-slate-800">
Add <span class="text-teal-600">Book</span>
</h1>
</div>

<form id="form" action="/admin/addBook" method="POST" enctype="multipart/form-data" class="space-y-4">

<!-- Book Title + Author -->
<div class="grid grid-cols-2 gap-3">

<div>
<label class="text-[10px] font-bold text-slate-500 uppercase">Book Title</label>
<input id="bookname" type="text" name="bookname" required
class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none">
<p id="bookerr" class="text-xs mt-1 hidden"></p>
</div>

<div>
<label class="text-[10px] font-bold text-slate-500 uppercase">Author</label>
<input id="author" type="text" name="author" required
class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none">
<p id="authorerr" class="text-xs mt-1 hidden"></p>
</div>

</div>

<!-- ISBN + Date -->
<div class="grid grid-cols-2 gap-3">

<div>
<label class="text-[10px] font-bold text-slate-500 uppercase">ISBN</label>
<input id="isbn" type="number" name="isbn" required
class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none">
<p id="isbnErr" class="text-xs mt-1 hidden"></p>
</div>

<div>
<label class="text-[10px] font-bold text-slate-500 uppercase">Entry Date</label>
<input id="date" type="date" name="date" required
class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none">
</div>

</div>

<!-- Quantity Full Width -->
<div>
<label class="text-[10px] font-bold text-slate-500 uppercase">Quantity</label>
<input id="quantity" type="number" name="quantity" required
class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none">
<p id="quantityErr" class="text-xs mt-1 hidden"></p>
</div>

<!-- Image Upload -->
<div class="bg-teal-50 p-3 rounded-xl border border-dashed border-teal-200">
<label class="text-[10px] font-bold text-teal-700 uppercase">Cover Image</label>
<input id="image" type="file" name="image" accept="image/*" required
class="w-full text-xs mt-1">
</div>

<!-- Buttons -->
<div class="flex flex-col gap-2 pt-2">

<button type="submit"
class="bg-teal-600 text-white py-2 rounded-xl text-sm font-bold hover:bg-teal-700 transition">
Add Book
</button>

<a href="/admin/dashboard"
class="text-center text-[10px] font-bold text-slate-400 hover:text-teal-600 uppercase">
Go Back
</a>

</div>

</form>
</div>


<script>
const form=document.getElementById('form')
const bookInp=document.getElementById('bookname')
const bookerr=document.getElementById('bookerr')

const authorInp=document.getElementById('author')
const authorerr=document.getElementById('authorerr')

const isbnInp=document.getElementById('isbn')
const isbnErr=document.getElementById('isbnErr')

const quantityInp=document.getElementById('quantity')
const quantityErr=document.getElementById('quantityErr')

form.addEventListener('submit',(e)=>{
e.preventDefault()
let isValid=true

if(bookInp.value.trim().length<3 || /\d/.test(bookInp.value)){
bookerr.textContent='Invalid name'
bookerr.className='text-red-600 text-xs mt-1'
bookInp.classList.add('border-red-500')
isValid=false
}else{
bookerr.classList.add('hidden')
}

if(authorInp.value.trim().length<3 || /\d/.test(authorInp.value)){
authorerr.textContent='Invalid author'
authorerr.className='text-red-600 text-xs mt-1'
authorInp.classList.add('border-red-500')
isValid=false
}else{
authorerr.classList.add('hidden')
}

if(!/^\d{10,13}$/.test(isbnInp.value.trim())){
isbnErr.textContent='ISBN must be 10-13 digits'
isbnErr.className='text-red-600 text-xs mt-1'
isbnInp.classList.add('border-red-500')
isValid=false
}else{
isbnErr.classList.add('hidden')
}

if(quantityInp.value.trim()==='' || Number(quantityInp.value)<=0){
quantityErr.textContent='Invalid quantity'
quantityErr.className='text-red-600 text-xs mt-1'
quantityInp.classList.add('border-red-500')
isValid=false
}else{
quantityErr.classList.add('hidden')
}

if(isValid){
form.submit()
}
})
</script>

</body>
</html>
