<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin Chat | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary-teal: #008080;
      --dark-teal: #004D4D;
    }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
    
    .teal-header {
      background: linear-gradient(135deg, #008080 0%, #004d4d 100%);
    }

    #chatBox::-webkit-scrollbar { width: 4px; }
    #chatBox::-webkit-scrollbar-track { background: transparent; }
    #chatBox::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

    .chat-bubble-admin {
      background: var(--primary-teal);
      color: white;
      border-radius: 1.25rem 1.25rem 0.25rem 1.25rem;
      box-shadow: 0 4px 12px -3px rgba(0, 128, 128, 0.3);
    }
    
    .chat-bubble-student {
      background: #f0fdfa;
      color: #004d4d;
      border-radius: 1.25rem 1.25rem 1.25rem 0.25rem;
      border: 1px solid #ccecec;
    }

    .animate-in { animation: fadeIn 0.3s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>

<body class="bg-slate-100 font-sans h-screen flex items-center justify-center p-4">

  <div class="w-full max-w-lg h-[85vh] bg-white rounded-[2.5rem] shadow-2xl flex flex-col overflow-hidden border border-slate-200">

    <header class="teal-header text-white px-8 py-6 flex items-center justify-between shadow-lg">
      <div class="flex items-center gap-4">
        <div class="relative">
          <div class="w-12 h-12 rounded-2xl bg-white/20 backdrop-blur-md flex items-center justify-center border border-white/30 text-white font-black text-lg">
            <%= studentName ? studentName.charAt(0).toUpperCase() : 'S' %>
          </div>
          <!-- <span class="absolute -bottom-1 -right-1 w-3.5 h-3.5 bg-emerald-400 border-2 border-[#004d4d] rounded-full"></span> -->
        </div>

        <div>
          <h3 class="text-sm font-black tracking-tight uppercase">
            <%= studentName || 'Unknown Student' %>
          </h3>
          <div class="flex items-center gap-1.5">
            <p class="text-[10px] font-bold text-teal-200 uppercase tracking-widest opacity-90">Private Chat</p>
          </div>
        </div>
      </div>

      <button id="closeModalBtn" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/10 text-white hover:bg-white/20 transition-all border border-white/10">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </header>

    <div id="chatBox" class="flex-1 p-8 space-y-6 overflow-y-auto bg-white scroll-smooth">
      </div>

    <footer class="p-6 bg-white border-t border-teal-50">
      <div class="relative flex items-center gap-3 bg-teal-50/50 border border-teal-100 rounded-[1.5rem] p-2 pr-3 focus-within:border-teal-500 focus-within:bg-white transition-all shadow-inner">
        <input
          type="text"
          id="msg"
          placeholder="Respond to student..."
          class="flex-1 bg-transparent px-4 py-2 text-sm text-slate-700 placeholder:text-teal-300 focus:outline-none"
          onkeydown="if(event.key==='Enter') sendMsg()"
        />

        <button
          onclick="sendMsg()"
          class="bg-teal-primary text-white p-3 rounded-2xl shadow-lg shadow-teal-900/20 hover:bg-teal-700 hover:-translate-y-0.5 active:scale-95 transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      </div>
    </footer>

  </div>

<script src="/socket.io/socket.io.js"></script>
<script>
  const fromUser = "<%= adminId %>";
  const toUser = "<%= studentId %>";
  const fromRole = "admin";
  const toRole = "student";
  
  const socket = io();
  let joined = false;

  socket.on('connect', () => {
    socket.emit("chat:join", { fromUser, toUser });
    joined = true;
  });
console.log(fromUser,toUser)
  function sendMsg() {
    if (!joined) return;
    const input = document.getElementById("msg");
    const txt = input.value.trim();
    if (!txt) return;
    socket.emit("chat:msg", { fromUser, toUser,  txt });
    input.value = "";
  }

  socket.on("chat:history", (messages) => {
    // const box = document.getElementById('chatBox');
    // box.innerHTML = "";
    // messages.forEach(showMsg);
      const box = document.getElementById("chatBox");
      if(messages.length > 0) {
      const empty=  document.getElementById('empty-chat')
      if(empty) empty.style.display='none'
      }
      messages.forEach(showMsg);
  });

  socket.on("chat:newMsg", (msg) => {
   // showMsg(msg);
    const empty=document.getElementById('empty-chat')
      if(empty) empty.style.display = 'none';
      showMsg(msg);
  });

  function showMsg(msg) {
    const box = document.getElementById("chatBox");
    const isMe =String(msg.senderId) === String(fromUser);
    
    const wrapper = document.createElement("div");
    wrapper.className = `flex w-full animate-in ${isMe ? "justify-end" : "justify-start"}`;

    const bubbleClass = isMe ? "chat-bubble-admin" : "chat-bubble-student";

    wrapper.innerHTML = `
      <div class="flex flex-col ${isMe ? 'items-end' : 'items-start'}">
        <div class="${bubbleClass} px-5 py-3 max-w-[80%] text-sm font-medium tracking-tight">
          <p class="leading-relaxed">${msg.message}</p>
        </div>
        
      </div>
    `;
    // <span class="text-[9px] text-slate-400 mt-1.5 px-1 font-bold uppercase tracking-tighter opacity-70">
        //     ${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
        // </span>

    box.appendChild(wrapper);
    box.scrollTop = box.scrollHeight;
  }

  document.getElementById('closeModalBtn').addEventListener('click', () => {
    window.location.href = '/admin/chatList';
  });
</script>

</body>
</html>