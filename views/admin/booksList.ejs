 <!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Books List | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="wave-bg h-screen overflow-hidden font-sans text-[#0D1B2A]">

<%- include('../partials/adminSidebar') %>

<main class="ml-20 p-8">

  <div class="max-w-7xl mx-auto 
              bg-white/80 backdrop-blur-xl 
              shadow-[0_32px_64px_-15px_rgba(13,27,42,0.12)]
              rounded-[2.5rem] overflow-hidden 
              border border-white">

    <!-- HEADER -->
    <div class="px-8 py-5 border-b border-slate-100 flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <h1 class="text-[22px] font-black text-slate-800">
          Library <span class="text-[#2D8B75]">BooksList</span>
        </h1>
       
      </div>

      <div class="flex items-center gap-4">
        <div class="relative">
          <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400">
            🔍
          </span>
          <input
            type="text"
            id="searchInp"
            placeholder="Search catalog..."
            class="w-72 pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus:ring-[#2D8B75]"
          />
        </div>

        <a href="/admin/addBook"
           class="bg-[#2D8B75] text-white p-3 rounded-2xl hover:bg-[#246f5e] transition-all shadow-lg">
          Add
        </a>
      </div>
    </div>

    <!-- TABLE -->
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-8 py-4 text-xs text-slate-400">ID</th>
            <th class="px-8 py-4 text-xs text-slate-400">Book</th>
            <th class="px-8 py-4 text-xs text-slate-400">Author</th>
            <th class="px-8 py-4 text-xs text-slate-400">ISBN</th>
            <th class="px-8 py-4 text-xs text-slate-400">Stock</th>
            <th class="px-8 py-4 text-xs text-slate-400">Date</th>
            <th class="px-8 py-4 text-xs text-right text-slate-400">Actions</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-slate-100">
          <% books.forEach((b,i) => { %>
          <tr class="book-row hover:bg-teal-50/30">
            <td class="px-8 py-5 text-xs text-slate-400">BK-<%=String ((currentPage-1)*4+i+1).padStart(3,'0') %></td>

            <td class="px-8 py-5 font-bold text-slate-700">
              <a href="/admin/viewDetails/<%= b.id %>" class="book-name hover:text-[#2D8B75]">
                <%= b.title%>
              </a>
            </td>

            <td class="px-8 py-5 text-sm text-slate-500"><%= b.author %></td>

            <td class="px-8 py-5 text-xs font-mono text-slate-600"><%= b.isbn %></td>

            <!-- <td class="px-8 py-5 text-xs text-slate-600"><%= b.availableCopies %>/<%=b.totalCopies%></td> -->

            <td class="px-8 py-5 text-xs font-bold">
  <% if (b.availableCopies === 0) { %>
    <span class="text-red-600">Out of Stock</span>
  <% } else if (b.availableCopies <= 3) { %>
    <span class="text-amber-600">
      Low Stock (<%= b.availableCopies %>/<%= b.totalCopies %>)
    </span>
  <% } else { %>
    <span class="text-emerald-600">
      Available (<%= b.availableCopies %>/<%= b.totalCopies %>)
    </span>
  <% } %>
</td>

            <td class="px-8 py-5 text-xs text-slate-400"><%= new Date(b.createdAt).toLocaleDateString()%></td>

           
            <td class="px-8 py-5 text-right">
  <div class="flex justify-end gap-2">

    <!-- EDIT -->
    <a href="/admin/edit/<%= b.id %>"
       class="inline-flex items-center justify-center
              px-4 py-2
              text-[11px] font-bold uppercase tracking-wider
              text-white bg-yellow-600
              rounded-xl
              hover:bg-yellow-500 hover:text-white
              transition">
      Edit
    </a>

    <!-- DELETE -->
    <button onclick="openDeleteModal('<%= b.id %>')"
            class="inline-flex items-center justify-center
                   px-4 py-2
                   text-[11px] font-bold uppercase tracking-wider
                   text-white bg-red-600
                   rounded-xl
                   hover:bg-red-500 hover:text-white
                   transition">
      Delete
    </button>

  </div>
</td>

          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%if(totalPages>1){%>
  <div class="flex justify-center items-center gap-2 py-10">

    <% if(currentPage>1){%>
      <a href="/admin/booksList?page=<%=currentPage -1 %>"  class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">Prev</a>


    <%}%>

   
    <%for(let i=1;i<=totalPages;i++){%>
  <a href="/admin/booksList?page=<%=i%>"class="px-4 py-2 rounded-xl text-sm font-bold
         <%= i === currentPage 
            ? 'bg-teal-600 text-white' 
            : 'bg-slate-100 text-slate-600 hover:bg-teal-100' %>"><%=i%></a>
    <%}%>

  

   <% if(currentPage < totalPages){%>
    <a href="/admin/booksList?page=<%=currentPage+1%>" class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">Next</a>

   <%}%>
  </div>
<%}%>
<!-- DELETE MODAL -->
<div id="deleteModal" class="fixed inset-0 hidden z-50 flex items-center justify-center">
  <div class="absolute inset-0 bg-black/40" onclick="closeDeleteModal()"></div>

  <div class="bg-white rounded-2xl p-6 w-full max-w-sm shadow-xl relative z-10">
    <p class="text-center text-[#2D8B75] font-semibold">
      Are you sure you want to delete this book?
    </p>

    <div class="flex justify-end gap-3 mt-6">
      <button onclick="closeDeleteModal()"
              class="px-4 py-2 bg-slate-100 rounded-xl text-slate-600">
        Cancel
      </button>

      <a id="confirmDeleteBtn"
         href="#"
         class="px-4 py-2 bg-[#2D8B75] text-white rounded-xl hover:bg-[#246f5e]">
        Delete
      </a>
    </div>
  </div>
</div>

<!-- JS -->
<script>
  function openDeleteModal(id) {
    document.getElementById('confirmDeleteBtn').href = `/admin/delete/${id}`;
    document.getElementById('deleteModal').classList.remove('hidden');
  }

  function closeDeleteModal() {
    document.getElementById('deleteModal').classList.add('hidden');
  }

  document.getElementById('searchInp').addEventListener('keyup', function () {
    const val = this.value.toLowerCase();
    document.querySelectorAll('.book-row').forEach(row => {
      row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
    });
  });
</script>

</body>
</html>


