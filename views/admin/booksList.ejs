 <!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Books List | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>

</head>
<body class="wave-bg min-h-screen font-sans text-[#0D1B2A]">

<%- include('../partials/adminSidebar') %>

<main class="ml-0 md:ml-20 p-3 md:p-8">

  <div class="max-w-7xl mx-auto 
              bg-white/80 backdrop-blur-xl 
              shadow-[0_32px_64px_-15px_rgba(13,27,42,0.12)]
              rounded-2xl md:rounded-[2.5rem] overflow-hidden 
              border border-white">

    <!-- HEADER -->
    <div class="px-4 md:px-8 py-4 md:py-5 border-b 
                flex flex-col md:flex-row justify-between gap-4">

      <h1 class="text-lg md:text-[22px] font-black text-slate-800">
        Library <span class="text-[#2D8B75]">BooksList</span>
      </h1>

      <div class="flex flex-col sm:flex-row gap-2 sm:items-center w-full sm:w-auto">

        <div class="relative w-full sm:w-64">
          <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
            🔍
          </span>

          <input
            type="text"
            id="searchInp"
            placeholder="Search catalog..."
            class="w-full pl-9 pr-3 py-2 bg-slate-50 border rounded-xl text-sm focus:ring-2 focus:ring-[#2D8B75]"
          />
        </div>

        <a href="/admin/addBook"
           class="bg-[#2D8B75] text-white px-4 py-2 rounded-xl text-sm text-center">
          Add
        </a>

      </div>
    </div>

    <!-- TABLE -->
    <div class="overflow-x-auto">
      <table class="w-full text-xs md:text-sm">

        <thead class="bg-slate-50">
          <tr>
            <th class="px-3 md:px-8 py-3  text-left">ID</th>
            <th class="px-3 md:px-8 py-3  text-left">Book</th>
            <th class="px-3 md:px-8 py-3  text-left">Author</th>
            <th class="px-3 md:px-8 py-3  text-left">ISBN</th>
            <th class="px-3 md:px-8 py-3  text-left">Stock</th>
            <th class="px-3 md:px-8 py-3  text-left">Date</th>
            <th class="px-3 md:px-8 py-3 text-right">Actions</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-slate-100">
          <% books.forEach((b,i) => { %>

          <tr class="book-row hover:bg-teal-50/30">

            <td class="px-3 md:px-8 py-3">
              BK-<%=String((currentPage-1)*4+i+1).padStart(3,'0') %>
            </td>

            <td class="px-3 md:px-8 py-3 font-bold">
              <a href="/admin/viewDetails/<%= b.id %>" class="hover:text-[#2D8B75]">
                <%= b.title %>
              </a>
            </td>

            <td class="px-3 md:px-8 py-3 text-slate-500">
              <%= b.author %>
            </td>

            <td class="px-3 md:px-8 py-3 text-xs font-mono">
              <%= b.isbn %>
            </td>

            <td class="px-3 md:px-8 py-3 text-xs font-bold">
              <% if (b.availableCopies === 0) { %>
                <span class="text-red-600">Out</span>
              <% } else if (b.availableCopies <= 3) { %>
                <span class="text-amber-600">
                  Low (<%= b.availableCopies %>/<%= b.totalCopies %>)
                </span>
              <% } else { %>
                <span class="text-emerald-600">
                  OK (<%= b.availableCopies %>/<%= b.totalCopies %>)
                </span>
              <% } %>
            </td>

            <td class="px-3 md:px-8 py-3 text-xs">
              <%= new Date(b.createdAt).toLocaleDateString() %>
            </td>

            <td class="px-3 md:px-8 py-3 text-right">
              <div class="flex flex-wrap justify-end gap-2">

                <a href="/admin/edit/<%= b.id %>"
                   class="px-2 md:px-4 py-1 md:py-2 text-xs font-bold bg-yellow-600 text-white rounded-lg">
                  Edit
                </a>

                <button onclick="openDeleteModal('<%= b.id %>')"
                        class="px-2 md:px-4 py-1 md:py-2 text-xs font-bold bg-red-600 text-white rounded-lg">
                  Delete
                </button>

              </div>
            </td>

          </tr>

          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
</main>

<!-- PAGINATION -->
<% if(totalPages>1){ %>
<div class="flex flex-wrap justify-center gap-2 py-6">

  <% if(currentPage>1){ %>
    <a href="?page=<%=currentPage-1%>" class="px-3 py-1 bg-slate-100 rounded">Prev</a>
  <% } %>

  <% for(let i=1;i<=totalPages;i++){ %>
    <a href="?page=<%=i%>" class="px-3 py-1 rounded 
    <%= i===currentPage ? 'bg-teal-600 text-white' : 'bg-slate-100' %>">
      <%=i%>
    </a>
  <% } %>

  <% if(currentPage<totalPages){ %>
    <a href="?page=<%=currentPage+1%>" class="px-3 py-1 bg-slate-100 rounded">Next</a>
  <% } %>

</div>
<% } %>
<!-- DELETE MODAL -->
<div id="deleteModal" class="fixed inset-0 hidden z-50 flex items-center justify-center">
  <div class="absolute inset-0 bg-black/40" onclick="closeDeleteModal()"></div>

  <div class="bg-white rounded-2xl p-6 w-full max-w-sm shadow-xl relative z-10">
    <p class="text-center text-[#2D8B75] font-semibold">
      Are you sure you want to delete this book?
    </p>

    <div class="flex justify-end gap-3 mt-6">
      <button onclick="closeDeleteModal()"
              class="px-4 py-2 bg-slate-100 rounded-xl text-slate-600">
        Cancel
      </button>

      <a id="confirmDeleteBtn"
         href="#"
         class="px-4 py-2 bg-[#2D8B75] text-white rounded-xl hover:bg-[#246f5e]">
        Delete
      </a>
    </div>
  </div>
</div>

<!-- JS -->
<script>
  function openDeleteModal(id) {
    document.getElementById('confirmDeleteBtn').href = `/admin/delete/${id}`;
    document.getElementById('deleteModal').classList.remove('hidden');
  }

  function closeDeleteModal() {
    document.getElementById('deleteModal').classList.add('hidden');
  }

  document.getElementById('searchInp').addEventListener('keyup', function () {
    const val = this.value.toLowerCase();
    document.querySelectorAll('.book-row').forEach(row => {
      row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
    });
  });
</script>

</body>
</html>


