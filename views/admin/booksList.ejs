<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Books List | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary-teal: #008080;
      --dark-teal: #004D4D;
      --soft-mint: #F0F8F8;
    }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
    .focus-ring-teal:focus { --tw-ring-color: var(--primary-teal); border-color: var(--primary-teal); }
  </style>
</head>

<body class="bg-slate-50 min-h-screen p-8 font-sans">
<%- include('../partials/adminSidebar')%>
  <main class="ml-20 p-8">
<div class="max-w-7xl mx-auto bg-white shadow-2xl shadow-teal-900/5 rounded-[2.5rem] overflow-hidden border border-slate-100">

    <div class="px-10 py-8 border-b border-slate-50 flex flex-col md:flex-row md:items-center justify-between gap-6 bg-white">
      <div>
        <h1 class="text-3xl font-black text-slate-800 tracking-tight">
          Library <span class="text-teal-600">BooksList</span>
        </h1>
        <p class="text-xs text-slate-400 font-bold uppercase tracking-[0.2em] mt-1">Manage & Monitor Books</p>
      </div>

      <div class="flex items-center gap-4">
        <div class="relative group">
          <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </span>
          <input
            type="text"
            id="searchInp"
            placeholder="Search catalog..."
            class="w-full md:w-72 pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all shadow-sm"
          />
        </div>
        
        <a href="/admin/addBook" class="bg-teal-primary text-white p-3 rounded-2xl hover:bg-teal-700 transition-all shadow-lg shadow-teal-900/10 group">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
        </a>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-slate-50/50">
            <th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Ref ID</th>
            <th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Book Title</th>
            <th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Author</th>
            <th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">ISBN</th>
            <th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Stock</th>
            <th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Arrival Date</th>
            <th class="px-8 py-4 text-right text-[10px] font-black text-slate-400 uppercase tracking-widest">Actions</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-slate-50">
          <% books.forEach((b)=> { %>
            <tr class="book-row group hover:bg-teal-50/30 transition-colors">
              <td class="px-8 py-5 text-xs font-bold text-slate-400">#<%= b.id %></td>
              
              <td class="px-8 py-5">
                <a href="/admin/viewDetails/<%= b.id %>" class="book-name text-sm font-bold text-slate-700 hover:text-teal-600 transition-colors">
                  <%= b.bookname %>
                </a>
              </td>

              <td class="px-8 py-5 text-sm text-slate-500 font-medium"><%= b.author %></td>
              
              <td class="px-8 py-5">
                <span class="text-[11px] font-mono bg-slate-100 text-slate-600 px-2 py-1 rounded-md border border-slate-200">
                  <%= b.isbn %>
                </span>
              </td>

              <td class="px-8 py-5">
                <% if(b.quantity > 5) { %>
                  <div class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                    <span class="text-xs font-bold text-emerald-600"><%= b.quantity %> Available</span>
                  </div>
                <% } else if(b.quantity > 0) { %>
                  <div class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                    <span class="text-xs font-bold text-amber-600"><%= b.quantity %> Low Stock</span>
                  </div>
                <% } else { %>
                  <div class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                    <span class="text-xs font-bold text-red-600">Out of Stock</span>
                  </div>
                <% } %>
              </td>

              <td class="px-8 py-5 text-[11px] text-slate-400 font-bold tracking-tight"><%= b.date %></td>

              <td class="px-8 py-5">
                <div class="flex justify-end gap-2">
                  <a href="/admin/edit/<%= b.id %>" class="p-2 text-slate-400 hover:text-teal-600 hover:bg-white rounded-xl transition-all shadow-sm border border-transparent hover:border-teal-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                    </svg>
                  </a>

                  <!-- <a href="/admin/delete/<%= b.id %>" onclick="return confirm('Are you sure you want to delete this book?')" class="p-2 text-slate-400 hover:text-red-500 hover:bg-white rounded-xl transition-all shadow-sm border border-transparent hover:border-red-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5-4h4a1 1 0 011 1v1H9V4a1 1 0 011-1z" />
                    </svg>
                  </a> -->
                  <button 
  onclick="openDeleteModal('<%= b.id %>')" 
  class="p-2 text-slate-400 hover:text-red-500 hover:bg-white rounded-xl transition-all shadow-sm border border-transparent hover:border-red-100">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none"
       viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5-4h4a1 1 0 011 1v1H9V4a1 1 0 011-1z" />
  </svg>
</button>

                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (books.length === 0) { %>
      <div class="py-20 text-center">
        <div class="text-4xl mb-4">📂</div>
        <h3 class="text-slate-800 font-bold">No books found</h3>
        <p class="text-slate-400 text-sm">Start by adding a new book to the catalog.</p>
      </div>
    <% } %>

  </div>


<!---pagination-->
<%if(totalPages>1){%>
  <div class="flex justify-center items-center gap-2 py-10">

    <!---prev button-->
    <% if(currentPage>1){%>
      <a href="/admin/booksList?page=<%=currentPage -1 %>"  class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">Prev</a>


    <%}%>

    <!--page number-->
    <%for(let i=1;i<=totalPages;i++){%>
  <a href="/admin/booksList?page=<%=i%>"class="px-4 py-2 rounded-xl text-sm font-bold
         <%= i === currentPage 
            ? 'bg-teal-600 text-white' 
            : 'bg-slate-100 text-slate-600 hover:bg-teal-100' %>"><%=i%></a>
    <%}%>

    <!--next button-->

   <% if(currentPage < totalPages){%>
    <a href="/admin/booksList?page=<%=currentPage+1%>" class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">Next</a>

   <%}%>
  </div>
<%}%>




  <a href="/admin/dashboard" 
   class="group inline-flex items-center gap-2 text-[#008080] text-[11px] font-black uppercase tracking-widest transition-all hover:text-[#006666]">
  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
  </svg>
  Back to Dashboard
</a>
  </main>
<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
  
  <!-- overlay -->
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeDeleteModal()"></div>

  <!-- modal box -->
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 relative z-10 animate-scale">
    
    <div class="text-center">
      
<p class="text-sm mt-2 text-teal-700 font-semibold">
  Are you sure you want to delete this book?
</p>


    </div>

    <div class="flex justify-end gap-3 mt-6">
      <button 
        onclick="closeDeleteModal()"
        class="px-4 py-2 text-sm font-bold rounded-xl bg-slate-100 text-slate-600 hover:bg-slate-200">
        Cancel
      </button>

    <a 
  id="confirmDeleteBtn"
  href="#"
  class="px-4 py-2 text-sm font-bold rounded-xl 
         bg-teal-600 text-white 
         hover:bg-teal-700 
         active:scale-95 
         transition-all">
  Delete
</a>

    </div>
  </div>
</div>
<script>
  let deleteBookId = null;

  function openDeleteModal(bookId) {
    deleteBookId = bookId;
    document.getElementById('confirmDeleteBtn').href = `/admin/delete/${bookId}`;
    document.getElementById('deleteModal').classList.remove('hidden');
  }

  function closeDeleteModal() {
    document.getElementById('deleteModal').classList.add('hidden');
    deleteBookId = null;
  }
</script>

  <script>
    const bookSearch = document.getElementById('searchInp');
    const rows = document.querySelectorAll('.book-row');

    bookSearch.addEventListener('keyup', function () {
      const val = bookSearch.value.toLowerCase().trim();

      rows.forEach(row => {
        const bookName = row.querySelector('.book-name').textContent.toLowerCase();
        row.style.display = bookName.includes(val) ? '' : 'none';
      });
    });
  </script>

</body>
</html>