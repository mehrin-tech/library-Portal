<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard | CollegeLibrary</title>


  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: '#0F766E',
            darkbg: '#0F3D3A',
            darkcard: '#115E59'
          }
        }
      }
    }
  </script>
  <!-- Dark flash prevent -->
  <script>
    if (localStorage.getItem("theme") === "dark") {
      document.documentElement.classList.add("dark");
    }
  </script>



</head>

<body class="
min-h-screen
bg-white
dark:bg-gradient-to-br
dark:from-[#0f3d3a]
dark:via-[#0f766e]
dark:to-[#063f3b]
text-slate-900
dark:text-white
transition-colors duration-500
">






  <%- include('../partials/adminSidebar') %>

    <main class="ml-24 p-8 max-w-7xl mx-auto">

      <!-- ================= HEADER ================= -->
    
<header
  class="mb-6 flex items-center justify-between
         px-8 py-5
         rounded-3xl
         bg-white
         dark:bg-white/5
         backdrop-blur-lg
         border border-slate-200
         dark:border-white/10
         shadow-lg
         transition-all duration-500">

  <div>
    <h1 class="text-2xl font-bold tracking-tight
               text-slate-900
               dark:text-white">
      College<span class="text-[#0F766E] dark:text-teal-300">Library</span>
    </h1>

    <p class="text-sm mt-1
              text-slate-500
              dark:text-white/60">
      Welcome back, Administrator
    </p>
  </div>

  <button id="themeToggle"
    class="w-12 h-12 rounded-2xl
           bg-slate-100
           dark:bg-white/10
           text-[#0F766E]
           dark:text-white
           hover:scale-105
           transition-all duration-300">
    🌙
  </button>

</header>

      <!-- ================= STATS ================= -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">



        <a href="/admin/booksList" class="group
  min-h-[200px]
  p-10
  bg-white/60
  dark:bg-[#115E59]/60
  backdrop-blur-lg
  border border-white/30
  dark:border-[#134E4A]
  shadow-xl
  hover:shadow-2xl
  hover:-translate-y-2
  rounded-3xl
  flex flex-col
  items-center
  justify-center
  text-center
  transition-all duration-300  ">

          <!-- Icon -->
          <div class="
      w-16 h-16
      bg-gradient-to-br
      from-[#14B8A6]
      to-[#0F766E]
      rounded-2xl
      flex items-center justify-center
      text-2xl text-white
      shadow-md
      mb-6">
            📚
          </div>

          <!-- Title -->
          <p class="
      text-xs
      uppercase
      tracking-[0.2em]
      text-[#0F766E] dark:text-white font-bold">
            Total Books
          </p>

          <!-- Count -->
          <h3 class="
      text-4xl
      font-extrabold
      mt-3
      text-[#0F766E] dark:text-white">
            <%= totalBooks %>
          </h3>

        </a>


        <!-- Total Students -->
        <a href="/admin/studentsList" class="group
  min-h-[200px]
  p-10
  bg-white/60
  dark:bg-[#115E59]/60
  backdrop-blur-lg
  border border-white/30
  dark:border-[#134E4A]
  shadow-xl
  hover:shadow-2xl
  hover:-translate-y-2
  rounded-3xl
  flex flex-col
  items-center
  justify-center
  text-center
  transition-all duration-300">

          <!-- Icon -->
          <div class="
      w-16 h-16
      bg-gradient-to-br
      from-[#14B8A6]
      to-[#0F766E]
      rounded-2xl
      flex items-center justify-center
      text-2xl text-white
      shadow-md
      mb-6">
            👥
          </div>

          <!-- Title -->
          <p class="
      text-xs
      uppercase
      tracking-[0.2em]
      text-[#0F766E] dark:text-white font-bold">
            Total Students
          </p>

          <!-- Count -->
          <h3 class="
      text-4xl
      font-extrabold
      mt-3
    text-[#0F766E] dark:text-white">
            <%= totalStudents %>
          </h3>

        </a>


        <!-- Books Issued -->
        <a href="/admin/issued-list" class="group
  min-h-[200px]
  p-10
  bg-white/60
  dark:bg-[#115E59]/60
  backdrop-blur-lg
  border border-white/30
  dark:border-[#134E4A]
  shadow-xl
  hover:shadow-2xl
  hover:-translate-y-2
  rounded-3xl
  flex flex-col
  items-center
  justify-center
  text-center
  transition-all duration-300">

          <!-- Icon -->
          <div class="
      w-16 h-16
      bg-gradient-to-br
      from-[#14B8A6]
      to-[#0F766E]
      rounded-2xl
      flex items-center justify-center
      text-2xl text-white
      shadow-md
      mb-6">
            🔄
          </div>

          <!-- Title -->
          <p class="
      text-xs
      uppercase
      tracking-[0.2em]
      text-[#0F766E] dark:text-white font-bold">
            Books Issued
          </p>

          <!-- Count -->
          <h3 class="
      text-4xl
      font-extrabold
      mt-3
      text-[#0F766E] dark:text-white
    ">
            <%= issuedCount %>
          </h3>

        </a>

        <!-- Pending Returns -->
        <div class="group
  min-h-[200px]
  p-10
  bg-white/60
  dark:bg-[#115E59]/60
  backdrop-blur-lg
  border border-white/30
  dark:border-[#134E4A]
  shadow-xl
  hover:shadow-2xl
  hover:-translate-y-2
  rounded-3xl
  flex flex-col
  items-center
  justify-center
  text-center
  transition-all duration-300">

          <!-- Icon -->
          <div class="
      w-16 h-16
      bg-gradient-to-br
      from-red-400
      to-red-600
      rounded-2xl
      flex items-center justify-center
      text-2xl text-white
      shadow-md
      mb-6">
            ⚠️
          </div>

          <!-- Title -->
          <p class="
      text-xs
      uppercase
      tracking-[0.2em]
      text-[#0F766E] dark:text-white font-bold">
            Pending Returns
          </p>

          <!-- Count -->
          <h3 class="
      text-4xl
      font-extrabold
      mt-3
      text-red-500
      dark:text-red-400">
            <%= pendingReturns %>
          </h3>

        </div>


      </div>

      <!-- ================= QUICK OPERATIONS ================= -->
      <div class="mb-12">
        <h2 class="text-xs font-semibold uppercase tracking-[0.25em] 
  text-white/50 mb-6">
          Quick Operations
        </h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">

          <!-- Add Book -->
          <a href="/admin/addBook" class="group flex flex-col items-center justify-center 
      p-8 
      bg-gradient-to-r from-[#14B8A6] to-[#0F766E]
      text-white 
      rounded-2xl 
      transition-all duration-300 
      shadow-xl 
      hover:scale-105">

            <div class="w-14 h-14 bg-white/20 rounded-xl 
      flex items-center justify-center mb-4 text-2xl
      group-hover:scale-110 transition">
              ➕
            </div>

            <span class="text-sm font-semibold text-white tracking-wide">
              Add Book
            </span>
          </a>

          <!-- Issue Book -->
          <a href="/admin/issue-book" class="group flex flex-col items-center justify-center 
      p-8 
      bg-gradient-to-r from-[#14B8A6] to-[#0F766E]
      text-white 
      rounded-2xl 
      transition-all duration-300 
      shadow-xl 
      hover:scale-105">

            <div class="w-14 h-14 bg-white/20 rounded-xl 
      flex items-center justify-center mb-4 text-2xl">
              📖
            </div>

            <span class="text-sm font-semibold tracking-wide">
              Issue Book
            </span>
          </a>

          <!-- Categories -->
          <a href="/admin/category/categoryList" class="group flex flex-col items-center justify-center 
      p-8 
      bg-gradient-to-r from-[#14B8A6] to-[#0F766E]
      text-white 
      rounded-2xl 
      transition-all duration-300 
      shadow-xl 
      hover:scale-105">

            <div class="w-14 h-14 bg-white/20 rounded-xl 
      flex items-center justify-center mb-4 text-2xl">
              📁
            </div>

            <span class="text-sm font-semibold text-white tracking-wide">
              Categories
            </span>
          </a>

          <!-- E-Book Readers -->
          <a href="/admin/online-readers" class="group flex flex-col items-center justify-center 
      p-8 
      bg-gradient-to-r from-[#14B8A6] to-[#0F766E]
      text-white 
      rounded-2xl 
      transition-all duration-300 
      shadow-xl 
      hover:scale-105">

            <div class="w-14 h-14 bg-white/20 rounded-xl 
      flex items-center justify-center mb-4 text-2xl">
              🧑‍💻
            </div>

            <span class="text-sm font-semibold text-white tracking-wide">
              E-Book Readers
            </span>
          </a>

        </div>
      </div>


      <!-- ================= CHARTS ================= -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

        <!-- Bar Chart -->
        <div class="
    bg-white/60
    dark:bg-[#115E59]/60
    backdrop-blur-lg
    border border-white/30
    dark:border-[#134E4A]
    shadow-lg
    rounded-2xl
    p-5
  ">

          <h2 class="
      text-[11px]
      font-semibold
      uppercase
      tracking-[0.2em]
      text-[#0F766E] dark:text-white

      mb-4">
            Department-wise Issued Books
          </h2>

          <div class="h-[180px]">
            <canvas id="deptChart"></canvas>
          </div>

        </div>


        <!-- Doughnut Chart -->
        <div class="
    bg-white/60
    dark:bg-[#115E59]/60
    backdrop-blur-lg
    
    dark:border-[#134E4A]
    shadow-lg
    rounded-2xl
    p-5
  ">

          <h2 class="
      text-[11px]
      font-semibold
      uppercase
      tracking-[0.2em]
     text-[#0F766E] dark:text-white

      mb-4">
            Library Overview
          </h2>

          <div class="h-[200px] w-full flex items-center justify-center">
            <canvas id="libraryPieChart"></canvas>
          </div>

        </div>

      </div>


    </main>

    <!-- ================= CHAT FLOAT BUTTON ================= -->
    <a href="/admin/chatList"
      class="fixed bottom-8 right-8 w-14 h-14 rounded-2xl bg-[#0F766E] text-white flex items-center justify-center shadow-xl hover:-translate-y-1 transition-all">
      <div class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 border-2 border-white rounded-full"></div>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
          d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
      </svg>
    </a>

    <!-- ================= CHART JS ================= -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


    <script>
      window.dashboardData = {
        deptLabels: <%- JSON.stringify(deptLabels) %>,
        deptValues: <%- JSON.stringify(deptValues) %>,
        totalBooks: <%= totalBooks %>,
        onlineReadersCount: <%= onlineReadersCount %>,
        totalStudents:<%= totalStudents %>,
        issuedCount: <%= issuedCount %>,
        finePaidCount: <%= finePaidCount %>,
        fineUnpaidCount: <%= fineUnpaidCount %>
      }
    </script>
    <script src="/javascript/chart.js"></script>

    <script src="/javascript/theme.js"></script>


</body>

</html>