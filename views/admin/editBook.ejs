<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Edit Book | Library System</title>
<script src="https://cdn.tailwindcss.com"></script>

<style>
:root {
  --primary-teal: #2D8B75;
}

/* scrollbar hide */
::-webkit-scrollbar {
  width: 0px;
}
body {
  scrollbar-width: none;
}

/* background */
.wave-bg {
  background-color: #F9FBFB;
}

/* file input */
.file-input-custom::-webkit-file-upload-button {
  background-color: var(--primary-teal);
  color: white;
  padding: 5px 12px;
  border-radius: 8px;
  font-size: 10px;
  font-weight: 800;
  margin-right: 8px;
}
</style>
</head>

<body class="wave-bg min-h-screen flex items-center justify-center p-2 md:p-4 font-sans overflow-y-auto">

<!-- CARD -->
<div class="bg-white/90 backdrop-blur-xl shadow-xl 
            rounded-2xl md:rounded-3xl 
            p-4 md:p-6 w-full max-w-xl border">

<!-- HEADER -->
<div class="text-center mb-4 md:mb-6">
  <h2 class="text-lg md:text-2xl font-black">
    Edit <span class="text-[#2D8B75]">Book</span>
  </h2>
 
</div>

<!-- FORM -->
<form action="/admin/update/<%= books.id %>" method="POST" enctype="multipart/form-data" class="space-y-4">

<div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">

<!-- TITLE -->
<div class="md:col-span-2">
<label class="text-[10px] font-bold text-slate-500">Title</label>
<input type="text" name="title" value="<%= books.title %>" required
class="w-full px-3 py-2 bg-slate-50 border rounded-xl text-sm focus:ring-2 focus:ring-[#2D8B75]">
</div>

<!-- AUTHOR -->
<div>
<label class="text-[10px] font-bold text-slate-500">Author</label>
<input type="text" name="author" value="<%= books.author %>" required
class="w-full px-3 py-2 bg-slate-50 border rounded-xl text-sm">
</div>

<!-- ISBN -->
<div>
<label class="text-[10px] font-bold text-slate-500">ISBN</label>
<input type="text" name="isbn" value="<%= books.isbn %>" required
class="w-full px-3 py-2 bg-slate-50 border rounded-xl text-sm">
</div>

<!-- QUANTITY -->
<div>
<label class="text-[10px] font-bold text-slate-500">Quantity</label>
<input type="number" name="availableCopies" value="<%= books.availableCopies %>" required
class="w-full px-3 py-2 bg-slate-50 border rounded-xl text-sm">
</div>

<!-- DATE -->
<div>
<label class="text-[10px] font-bold text-slate-500">Date</label>
<input type="date" name="publishedDate"
value="<%= books.publishedDate?.toISOString().split('T')[0] %>"
class="w-full px-3 py-2 bg-slate-50 border rounded-xl text-sm">
</div>

<!-- IMAGE -->
<div class="md:col-span-2 flex flex-col sm:flex-row items-center gap-3 p-3 bg-[#2D8B75]/5 rounded-xl border">

<img src="<%= books.image %>"
class="w-14 h-16 md:w-16 md:h-20 rounded-lg object-cover">

<div class="w-full">
<label class="text-[10px] font-bold text-[#2D8B75] block mb-1">
Change Image
</label>

<input type="file" name="image"
class="file-input-custom w-full text-[10px]">
</div>

</div>

</div>

<!-- ACTION -->
<div class="pt-3 border-t flex flex-col gap-2">

<button type="submit"
class="w-full bg-[#2D8B75] text-white py-2 rounded-xl text-sm font-bold">
Update
</button>

<a href="/admin/booksList"
class="text-center text-[10px] text-slate-400">
Cancel
</a>

</div>

</form>

</div>

</body>
</html>