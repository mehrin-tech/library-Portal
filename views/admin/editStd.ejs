<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Student | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary-teal: #008080;
      --dark-teal: #004D4D;
    }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .focus-ring-teal:focus { 
      --tw-ring-color: var(--primary-teal); 
      border-color: var(--primary-teal); 
    }
    .file-input-custom::-webkit-file-upload-button {
      background-color: var(--primary-teal);
      color: white;
      padding: 6px 12px;
      border: none;
      border-radius: 8px;
      font-size: 11px;
      font-weight: bold;
      cursor: pointer;
      margin-right: 10px;
    }
  </style>
</head>

<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6 font-sans">

  <div class="bg-white shadow-2xl shadow-teal-900/10 rounded-[2.5rem] p-10 w-full max-w-2xl border border-slate-100 relative overflow-hidden">
    
    <div class="absolute top-0 left-0 w-full h-2 bg-teal-primary"></div>

    <div class="text-center mb-10">
      <div class="relative inline-block mb-4">
         <div class="w-24 h-24 rounded-full border-4 border-white shadow-lg overflow-hidden bg-slate-100 mx-auto">
            <img src="<%= user.image || 'https://via.placeholder.com/150' %>" alt="Student Photo" class="w-full h-full object-cover">
         </div>
         <div class="absolute bottom-0 right-0 bg-teal-primary p-2 rounded-full border-2 border-white shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-white" viewBox="0 0 20 20" fill="currentColor">
                <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
            </svg>
         </div>
      </div>
      <h2 class="text-3xl font-black text-slate-800 tracking-tight">Edit <span class="text-teal-600">Profile</span></h2>
      <p class="text-[11px] text-slate-400 font-black uppercase tracking-[0.2em] mt-1">Student Record: #<%= user.id %></p>
    </div>

    <form action="/admin/updateStd/<%= user.id %>" method="POST" enctype="multipart/form-data" class="space-y-6">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
        
        <div class="md:col-span-2">
          <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Full Name</label>
          <input type="text" name="username" value="<%= user.username %>" required
            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all">
        </div>

        <div>
          <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Student ID</label>
          <input type="number" name="code" value="<%= user.rollNo %>" required
            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all">
        </div>

        <div>
          <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Email</label>
          <input type="email" name="email" value="<%= user.email %>" required
            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all">
        </div>

        <div>
          <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Department</label>
          <input type="text" name="department" value="<%= user.department %>" required
            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all">
        </div>

        <div>
          <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Semester</label>
          <input type="text" name="semester" value="<%= user.semester %>" required
            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all">
        </div>

        <div>
          <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Status</label>
          <select name="status" required
            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all appearance-none">
            <option value="Active" <%= user.status === 'Active' ? 'selected' : '' %>>Active</option>
            <option value="Inactive" <%= user.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
          </select>
        </div>

        <div class="md:col-span-2 bg-teal-50/30 p-4 rounded-2xl border border-dashed border-teal-200">
          <label class="block text-[11px] font-black text-teal-700 uppercase tracking-widest mb-2 ml-1">Update Profile Photo</label>
          <input type="file" name="image" accept="image/*"
            class="file-input-custom w-full text-[11px] text-slate-400">
        </div>
      </div>

      <div class="pt-6 border-t border-slate-50 flex flex-col gap-3">
        <button type="submit"
          class="w-full bg-teal-primary text-white py-4 rounded-2xl hover:bg-teal-700 transition-all font-bold shadow-lg shadow-teal-900/20 active:scale-[0.98]">
          Save Changes
        </button>
        <a href="/admin/studentsList" class="text-center text-[11px] font-black text-slate-400 hover:text-teal-600 transition-colors uppercase tracking-widest">
          Go back to Student List
        </a>
      </div>

    </form>
  </div>

</body>
</html>