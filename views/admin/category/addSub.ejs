<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Subcategory | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary-teal: #008080;
    }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
    .focus-ring-teal:focus { 
      --tw-ring-color: var(--primary-teal); 
      border-color: var(--primary-teal); 
    }
  </style>
</head>

<body class="bg-slate-50 min-h-screen p-6 md:p-12 font-sans">

  <div class="max-w-2xl mx-auto mb-10 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-black text-slate-800 tracking-tight">
        Add <span class="text-teal-600">Subcategory</span>
      </h1>
      <div class="mt-2 flex items-center gap-2">
        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Parent Category:</span>
        <span class="px-3 py-1 bg-teal-50 text-teal-700 text-[10px] font-black uppercase tracking-widest rounded-full border border-teal-100">
          <%= category.category %>
        </span>
      </div>
    </div>
    
    <a href="/admin/categories" class="p-2 bg-white border border-slate-200 rounded-xl text-slate-400 hover:text-teal-600 transition-colors shadow-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </a>
  </div>

  <form
    action="/admin/category/<%= category.id %>/sub/add"
    method="POST"
    enctype="multipart/form-data"
    class="max-w-2xl mx-auto bg-white p-10 rounded-[2.5rem] shadow-2xl shadow-teal-900/5 border border-slate-100 space-y-8 relative overflow-hidden"
  >
    <div class="absolute top-0 left-0 w-full h-2 bg-teal-primary"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="md:col-span-1">
        <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Subcategory Name</label>
        <input
          type="text"
          name="subcategory"
          placeholder="e.g. Fantasy"
          required
          class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all shadow-sm placeholder:text-slate-300"
        />
      </div>

      <div class="md:col-span-1">
        <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Featured Book Title</label>
        <input
          type="text"
          name="bookTitle"
          placeholder="e.g. Peter Pan"
          required
          class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all shadow-sm placeholder:text-slate-300"
        />
      </div>
    </div>

    <div>
      <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Classification Description</label>
      <textarea
        name="description"
        rows="4"
        placeholder="Provide a brief overview of what this subcategory covers..."
        required
        class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all shadow-sm placeholder:text-slate-300"
      ></textarea>
    </div>

    <div>
      <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Visual Identifier (Image)</label>
      <div class="mt-1 flex justify-center px-6 pt-6 pb-6 border-2 border-slate-200 border-dashed rounded-[2rem] bg-slate-50 hover:bg-teal-50/50 transition-colors group">
        <div class="space-y-2 text-center">
          <svg class="mx-auto h-10 w-10 text-slate-300 group-hover:text-teal-400 transition-colors" stroke="currentColor" fill="none" viewBox="0 0 48 48">
            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <div class="flex text-sm text-slate-600 justify-center">
            <label class="relative cursor-pointer font-black text-teal-600 hover:text-teal-700">
              <span>Select Artwork</span>
              <input name="image" type="file" accept="image/*" class="sr-only">
            </label>
          </div>
          <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">JPG, PNG up to 5MB</p>
        </div>
      </div>
    </div>

    <button
      type="submit"
      class="w-full bg-teal-primary text-white py-4 rounded-2xl hover:bg-teal-700 transition-all font-bold shadow-xl shadow-teal-900/20 active:scale-[0.98] flex items-center justify-center gap-3"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
      </svg>
      Commit Subcategory
    </button>

  </form>

</body>
</html>