<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Book</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6 font-sans overflow-hidden">

<!-- Wider Container -->
<div class="w-full max-w-2xl bg-white shadow-xl rounded-xl border overflow-hidden">

<!-- Header -->
<div class="px-10 py-6 border-b bg-white">
<h1 class="text-center  text-2xl font-black text-slate-800">
Edit <span class="text-teal-600">Book</span>
</h1>


</div>

<!-- Form -->
<div class="p-10">

<form
action="/admin/category/edit-subcategory/<%= category.id %>/<%= subId %>"
method="POST"
enctype="multipart/form-data"
class="space-y-6"
>

<!-- 2 Column Layout -->
<div class="grid grid-cols-2 gap-6">

<!-- Book Title -->
<div>
<label class="text-xs font-bold text-slate-500 uppercase">
Book Title
</label>

<input
id="titleInp"
type="text"
name="bookTitle"
value="<%= subCategory.bookTitle %>"
required
class="w-full mt-1 px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none"
/>

<p id="titleError" class="text-red-500 text-xs mt-1 hidden"></p>
</div>


<!-- Author -->
<div>
<label class="text-xs font-bold text-slate-500 uppercase">
Author
</label>

<input
id="authorInp"
type="text"
name="author"
value="<%= subCategory.author || '' %>"
required
class="w-full mt-1 px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none"
/>

<p id="authorError" class="text-red-500 text-xs mt-1 hidden"></p>
</div>

</div>

<!-- Description + PDF Side Layout -->
<div class="grid grid-cols-2 gap-6">

<!-- Description LEFT -->
<div>
<label class="text-xs font-bold text-slate-500 uppercase">
Description
</label>

<textarea
id="descInp"
name="description"
rows="3"
required
class="w-full mt-1 px-3 py-2 border rounded-lg text-sm focus:ring-2 focus:ring-teal-500 outline-none"
><%= subCategory.description %></textarea>

<p id="descError" class="text-red-500 text-xs mt-1 hidden"></p>
</div>


<!-- PDF RIGHT -->
<div>
<label class="text-xs font-bold text-slate-500 uppercase">
Upload PDF
</label>

<input
type="file"
name="pdf"
accept="application/pdf"
class="w-full mt-1 border rounded-lg p-2 text-sm"
/>
</div>

</div>


<!-- Buttons -->
<div class="flex justify-between pt-6 border-t">

<a href="/admin/category/view/<%= category.id %>"
class="text-xs font-bold text-slate-400 uppercase hover:text-slate-600">
← Back
</a>

<button
type="submit"
class="px-8 py-2 bg-teal-600 text-white text-xs font-bold uppercase rounded-lg hover:bg-teal-700 transition">
Update
</button>

</div>

</form>
</div>
</div>

</body>
</html>
