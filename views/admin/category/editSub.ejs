<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Subcategory | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6 font-sans">

  <div class="w-full max-w-xl bg-white shadow-2xl rounded-[2.5rem] p-10 border relative">

    <div class="mb-8 text-center">
      <h1 class="text-3xl font-black text-slate-800">
        Edit <span class="text-teal-600">Book Details</span>
      </h1>
      <p class="text-xs text-slate-400 uppercase tracking-widest mt-2">
        <%= category.category %>
      </p>
    </div>

    <form
      action="/admin/category/edit-subcategory/<%= category.id %>/<%= subId %>" enctype="multipart/form-data"
      method="POST"
      class="space-y-6"
    >

  
      <!-- Book Title -->
      <div>
        <label class="text-xs font-bold text-slate-500 uppercase">Book Title</label>
        <input id="titleInp"
          type="text"
          name="bookTitle"
          value="<%= subCategory.bookTitle %>"
          required
          class="w-full mt-2 px-4 py-3 border rounded-xl"
        />
        <p id="titleError" class="text-red-500 text-xs mt-1 hidden"></p>
      </div>

      <!-- Author -->
      <div>
        <label class="text-xs font-bold text-slate-500 uppercase">Author</label>
        <input id="authorInp"
          type="text"
          name="author"
          value="<%= subCategory.author || '' %>"
          required
          class="w-full mt-2 px-4 py-3 border rounded-xl"
        />
        <p id="authorError" class="text-red-500 text-xs mt-1 hidden"></p>

      </div>

      <!-- Description -->
      <div>
        <label class="text-xs font-bold text-slate-500 uppercase">Description</label>
        <textarea  id="descInp"
          name="description"
          rows="4"
          required
          class="w-full mt-2 px-4 py-3 border rounded-xl"
        ><%= subCategory.description %></textarea>
        <p id="descError" class="text-red-500 text-xs mt-1 hidden"></p>
      </div>

      <div>
  <label class="block text-xs font-bold text-slate-500 mb-2">
    Upload PDF (optional)
  </label>
  <input 
    type="file"
    name="pdf"
    accept="application/pdf"
    class="w-full border rounded-lg p-2" required
  />
</div>

      <!-- Actions -->
      <div class="flex justify-between pt-6 border-t">
        <a
          href="/admin/category/view/<%= category.id %>"
          class="text-xs font-bold text-slate-400 uppercase"
        >
          ← Back
        </a>

        <button
          type="submit"
          class="px-8 py-3 bg-teal-600 text-white text-xs font-bold uppercase rounded-xl"
        >
          Update
        </button>
      </div>

    </form>
  </div>

  <script>
  const form = document.querySelector("form");

  const subInp = document.getElementById("subInp");
  const titleInp = document.getElementById("titleInp");
  const authorInp = document.getElementById("authorInp");
  const descInp = document.getElementById("descInp");


  const subError = document.getElementById("subError");
  const titleError = document.getElementById("titleError");
  const authorError = document.getElementById("authorError");
  const descError = document.getElementById("descError");
 

  // Regex patterns
  const subRegex = /^[a-zA-Z ]{3,}$/;
  const titleRegex = /^[a-zA-Z ]{3,}$/;
  const authorRegex = /^[a-zA-Z ]{2,}$/;

  form.addEventListener("submit", function (e) {
    let isValid = true;

    /* ---- Subcategory ---- */
    if (!subRegex.test(subInp.value.trim())) {
      subError.textContent = "Subcategory must be at least 3 letters.";
      subError.classList.remove("hidden");
      isValid = false;
    } else subError.classList.add("hidden");

    /* ---- Book Title ---- */
    if (!titleRegex.test(titleInp.value.trim())) {
      titleError.textContent = "Book title must be at least 3 characters.";
      titleError.classList.remove("hidden");
      isValid = false;
    } else titleError.classList.add("hidden");

    /* ---- Author ---- */
    if (!authorRegex.test(authorInp.value.trim())) {
      authorError.textContent = "Author must contain only letters.";
      authorError.classList.remove("hidden");
      isValid = false;
    } else authorError.classList.add("hidden");

    /* ---- Description ---- */
    if (descInp.value.trim().length < 10) {
      descError.textContent = "Description must be at least 10 characters.";
      descError.classList.remove("hidden");
      isValid = false;
    } else descError.classList.add("hidden");

   

    if (!isValid) {
      e.preventDefault(); 
    }
  });
</script>

</body>
</html>
