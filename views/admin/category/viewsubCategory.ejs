<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= category.category %> - Subcategories</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-50 h-screen font-sans  ">
<%- include('../../partials/adminSidebar') %>

<main class="ml-20 p-8">
  <div class="max-w-full mx-auto px-6 ">



   <div class="bg-teal-800 rounded-2xl p-5 mb-6 text-white flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
  

  <div> 
    <h1 class="text-lg font-black font-extrabold"><%= category.category %></h1>
   
   </div> 

 
   <a
    href="/admin/category/<%= category.id %>/sub/add"
    class="inline-flex items-center gap-2 px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white text-xs font-black uppercase tracking-widest rounded-2xl transition-all shadow-lg shadow-teal-900/30 active:scale-95"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none"
         viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 4v16m8-8H4" />
    </svg>
    Add Subcategory
  </a>

</div> 


  <!-- TABLE -->
  <div class="bg-white rounded-3xl shadow border overflow-hidden">
 
    <% if (sub && sub.length > 0) { %>
    <table class="w-full">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-4 text-xs text-slate-400">ID</th>
          <th class="px-6 py-4 text-xs text-slate-400">Cover</th>
          <th class="px-6 py-4 text-xs text-slate-400">Author</th>
          <th class="px-6 py-4 text-xs text-slate-400">Book Title</th>
          <th class="px-6 py-4 text-xs text-slate-400">Description</th>
          <th class="px-6 py-4 text-xs text-slate-400 text-center">Control</th>
        </tr>
      </thead>

      <tbody>
      <% sub.forEach((s,i )=> { %>
        <tr class="border-t hover:bg-slate-50">

          <td class="px-6 py-5 text-sm text-slate-500">#<%= i+1 %></td>

          <td class="px-6 py-5">
            <% if (s.image) { %>
             <a href="/admin/category/<%=category.id%>/book/<%=s.id%>"><img
                src="/uploads/<%= s.image %>"
                class="w-14 h-20 object-cover rounded-xl shadow cursor-pointer"
                data-image="/uploads/<%= s.image %>"
                data-title="<%= s.bookTitle %>"
                data-description="<%= s.description || 'No description available' %>"
            
              ></a>
            <% } else { %>
              <div class="w-14 h-20 bg-slate-100 rounded-xl flex items-center justify-center text-xs text-slate-400">
                Empty
              </div>
            <% } %>
          </td>

          <td class="px-6 py-5 text-sm font-semibold"><%= s.author %></td>
          <td class="px-6 py-5 text-sm"><%= s.bookTitle %></td>
            <!-- <td class="px-6 py-5 text-sm"><%= s.author %></td> -->
          <td class="px-6 py-5 text-xs text-slate-500 max-w-xs italic">
            "<%= s.description ? s.description.substring(0, 60) + '...' : 'No description' %>"
          </td>

        <td class="px-6 py-5 text-center space-x-2">

  <!-- EDIT -->
  <a
    href="/admin/category/<%= category.id %>/sub/<%= s.id %>/edit"
    class="inline-flex items-center justify-center
           px-4 py-1.5
           text-xs font-bold uppercase tracking-wider
           text-white bg-yellow-600
           rounded-lg
           hover:bg-yellow-500 hover:text-white
           transition-all"
  >
    Edit
  </a>

  <!-- DELETE -->
  <button
    onclick="deleteModal('/admin/category/<%=category.id%>/sub/<%=s.id%>/delete')"
    class="inline-flex items-center justify-center
           px-4 py-1.5
           text-xs font-bold uppercase tracking-wider
           text-white bg-red-600
           rounded-lg
           hover:bg-red-500 hover:text-white
           transition-all"
  >
    Delete
  </button>

</td>


        </tr>
      <% }) %>
      </tbody>
   </table>
    <% } else { %>
      <p class="p-10 text-center text-slate-400">No subcategories found</p>
    <% } %>

  </div>

</div>
 <!---pagination-->

  <%if(totalPages>=1){%>
<div class="flex justify-center items-center gap-2 py-10">


  <!--prev button-->
  <%if(currentPage>1){%>
<a href="/admin/category/view/<%= category.id %>?page=<%= currentPage - 1 %>" class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">prev</a>

 <% }%>

 <!--page number-->
 <%for(let i=1;i<=totalPages;i++){%>
   <a href="/admin/category/view/<%= category.id %>?page=<%= i %>"class="px-4 py-2 rounded-xl text-sm font-bold
         <%= i === currentPage 
            ? 'bg-teal-600 text-white' 
            : 'bg-slate-100 text-slate-600 hover:bg-teal-100' %>"><%=i%></a>

 <%}%>


 <!--next button-->
 <%if(currentPage< totalPages){%>
<a href="/admin/category/view/<%= category.id %>?page=<%= currentPage + 1 %>" class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">next</a>

 <%}%>
</div>
  <%}%>
</main>

<!----================= MODAL ================-->
 
<div
  id="deleteModal"
  class="fixed inset-0 hidden z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center"
>
  <div class="bg-white rounded-2xl p-6 w-[90%] max-w-md shadow-xl">

        <h2 class="text-xl font-bold text-slate-800 mb-3">
      Delete Book
    </h2>
<p class="text-slate-600 mb-6">
      Are you sure you want to delete this book?
      </p>
      
  <div class="flex justify-end gap-4">
      <!-- CANCEL -->
      <button
        onclick="closeDeleteModal()"
        class="px-5 py-2 rounded-lg border text-slate-500 hover:bg-slate-100"
      >
        Cancel
      </button>
       <!-- OK / CONFIRM -->
      <a
        id="confirmDeleteBtn"
        href="#"
        class="px-5 py-2 rounded-lg bg-rose-600 text-white hover:bg-rose-700"
      >
        OK
      </a>
      </div>
      </div>
      </div>
<!-- ================= JS ================= -->
<script>
  function deleteModal(deleteUrl) {
    document.getElementById('confirmDeleteBtn').href = deleteUrl;
    document.getElementById('deleteModal').classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }

  function closeDeleteModal() {
    document.getElementById('deleteModal').classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }
</script>





</body>
</html>
