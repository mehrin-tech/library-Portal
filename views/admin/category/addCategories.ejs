<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Create Category | College Library</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    :root {
      --primary-emerald: #2D8B75;
      --deep-navy: #0D1B2A;
    }

    .wave-bg {
      background-color: #F9FBFB;
    }
    body{
      overflow-x: hidden;
    }
  </style>
</head>
<body class="wave-bg min-h-screen font-sans text-[#0D1B2A]">

  <div class="relative min-h-screen flex items-center justify-center px-4 py-8 md:p-6">

   

    <!-- Card -->
    <div class="relative z-10 w-full max-w-md lg:max-w-xl">
      <div class="bg-white/80 backdrop-blur-xl rounded-2xl md:rounded-[2.5rem] p-4 md:p-12
                  shadow-[0_32px_64px_-15px_rgba(13,27,42,0.15)]
                  border border-white">

        <!-- Header -->
        <div class="text-center mb-6 md:mb-10">

          <h1 class="text-xl md:text-3xl font-bold tracking-tight">
            Create <span class="text-[#2D8B75]">Category</span>
          </h1>

        </div>

        <!-- Form -->
        <form id="categoryForm"
          action="/admin/category/add"
          method="POST"
          enctype="multipart/form-data"
          class="space-y-4 md:space-y-6">

          <!-- Category -->
          <div>
            <label class="block text-[10px] md:text-[11px] font-bold uppercase mb-2">
              Category Name
            </label>

            <input id="categoryInp"
              type="text"
              name="category"
              required
              class="w-full px-4 py-3 md:px-6 md:py-4 bg-white/60 border rounded-2xl text-sm focus:ring-2 focus:ring-[#2D8B75]"
            />

            <p id="categoryError" class="text-red-500 text-xs mt-1 hidden"></p>
          </div>

          <!-- Image -->
          <div>
            <label class="block text-[10px] md:text-[11px] font-bold uppercase mb-2">
              Book Cover Image
            </label>

            <input id="imgInp"
              type="file"
              name="image"
              accept="image/*"
              required
              class="w-full px-4 py-3 md:px-6 md:py-4
transition-all duration-300 bg-white/60 border rounded-2xl text-sm focus:ring-2 focus:ring-[#2D8B75]"
            />
          </div>

          <!-- Actions -->
          <div class="pt-4 md:pt-6 flex flex-col gap-3 md:gap-4">

            <button type="submit"
              class="w-full bg-[#2D8B75] hover:bg-[#257561]
text-white py-3 md:py-4 rounded-2xl
font-bold transition-all duration-300
active:scale-[0.98]">
              Create Category
            </button>

            <a href="/admin/category/categoryList"
              class="text-center text-xs font-bold text-slate-400">
              Cancel & Go Back
            </a>

          </div>

        </form>
      </div>
    </div>

  </div>


<script>
  const form=document.getElementById('categoryForm')

  const categoryInp=document.getElementById('categoryInp')

  const categoryError=document.getElementById('categoryError')

  //regex patterns
  const categoryRegex=/^[a-zA-Z ]{3,}$/

  form.addEventListener('submit',(e)=>{
    let isValid=true;

    if(!categoryRegex.test(categoryInp.value.trim())){
      categoryError.textContent= "Category name must contain only letters and at least 3 characters."

      categoryError.classList.remove('hidden')
      isValid=false;
    }else{
      categoryError.classList.add('hidden')
    }



if(!isValid){
  e.preventDefault()
}




  })

</script>
</body>
</html>
