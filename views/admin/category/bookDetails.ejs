<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= book.bookTitle %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-100 min-h-screen font-sans">

  <!-- Container -->
  <div class="max-w-6xl mx-auto px-3 md:px-6 py-6 md:py-10">

    <!-- Book Header -->
    <div class="bg-white rounded-xl shadow-lg p-4 md:p-8 mb-6 md:mb-8 
                flex flex-col md:flex-row gap-4 md:gap-8">

      <!-- Book Image -->
      <div class="flex-shrink-0 flex justify-center md:justify-start">
        <img
          src="<%= book.image %>"
          alt="<%= book.bookTitle %>"
          class="w-32 md:w-48 h-auto rounded-xl md:rounded-2xl shadow-md"
        >
      </div>

      <!-- Book Info -->
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-xl md:text-3xl font-black text-slate-900 mb-2">
          <%= book.bookTitle %>
        </h1>

        <p class="text-teal-600 font-semibold mb-3 md:mb-4 text-sm md:text-base">
          <%= book.author %>
        </p>

        <p class="text-slate-600 leading-relaxed text-xs md:text-sm">
          <%= book.description %>
        </p>
      </div>
    </div>

    <!-- PDF Reader -->
    <div class="bg-white rounded-xl shadow-lg p-3 md:p-6">

      <h2 class="text-lg md:text-xl font-bold text-slate-800 mb-3 md:mb-4">
        📖 Read Book
      </h2>

      <% if (book.pdf) { %>
        <div class="w-full h-[60vh] md:h-[75vh] rounded-xl overflow-hidden border">
        <!-- <iframe
            src="<%= book.pdf %>?fl_attachment=false#toolbar=0&navpanes=0&scrollbar=0"
            class="w-full h-full"
            style="border:none"
          ></iframe> -->
<iframe
  src="https://docs.google.com/gview?embedded=true&url=<%= encodeURIComponent(book.pdf) %>"
  class="w-full h-full"
  style="border:none"
></iframe>
        </div>
      <% } else { %>
        <p class="text-slate-400 italic text-sm">
          PDF not available
        </p>
      <% } %>

    </div>

  </div>

</body>
</html>