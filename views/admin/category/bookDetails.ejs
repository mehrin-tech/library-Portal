<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= book.bookTitle %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-100 min-h-screen font-sans">

  <!-- Container -->
  <div class="max-w-6xl mx-auto px-6 py-10">

    <!-- Book Header -->
    <div class="bg-white rounded-3xl shadow-lg p-8 mb-8 flex flex-col md:flex-row gap-8">

      <!-- Book Image -->
      <div class="flex-shrink-0">
        <img
          src="/uploads/<%= book.image %>"
          alt="<%= book.bookTitle %>"
          class="w-48 h-auto rounded-2xl shadow-md"
        >
      </div>

      <!-- Book Info -->
      <div class="flex-1">
        <h1 class="text-3xl font-black text-slate-900 mb-2">
          <%= book.bookTitle %>
        </h1>

        <p class="text-teal-600 font-semibold mb-4">
          <%= book.author %>
        </p>

        <p class="text-slate-600 leading-relaxed text-sm">
          <%= book.description %>
        </p>
      </div>
    </div>

    <!-- PDF Reader -->
    <div class="bg-white rounded-3xl shadow-lg p-6">

      <h2 class="text-xl font-bold text-slate-800 mb-4">
        📖 Read Book
      </h2>

      <% if (book.pdf) { %>
        <div class="w-full h-[75vh] rounded-2xl overflow-hidden border">
          <iframe
            src="/uploads/<%= book.pdf %>#toolbar=0&navpanes=0&scrollbar=0"
            class="w-full h-full"
            style="border:none"
          ></iframe>
        </div>
      <% } else { %>
        <p class="text-slate-400 italic">
          PDF not available
        </p>
      <% } %>

    </div>

  </div>


  

</body>
</html>
