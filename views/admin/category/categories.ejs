<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Category Registry | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>

</head>

 <body class="bg-slate-50 min-h-screen font-sans overflow-hidden">
<%- include('../../partials/adminSidebar')%>
 <main class="ml-20 p-8">
<div class="max-w-full mx-auto px-6 ">

  <div class="bg-teal-800 rounded-lg p-5 mb-12 shadow-2xl shadow-slate-900/20 relative overflow-hidden">
    <div class="absolute -top-24 -right-24 w-64 h-20 bg-teal-500/10 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 flex flex-col lg:flex-row lg:items-center justify-between gap-4">
      <div>
        <h1 class="text-xl font-black text-slate-900 tracking-tight">
          Collection <span class="text-white">Categories</span>
        </h1>
        
      </div>

      <div class="flex-1 max-w-xl">
        <div class="relative">
          <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </span>
          <input
            type="text"
            id="searchCategory"
            placeholder="Search categories, authors, or IDs..."
            class="w-full pl-12 pr-4 py-2.5 bg-slate-50 border border-teal-700 rounded-2xl text-slate-900 placeholder-slate-500 focus:outline-none focus:ring-2 focus-ring-teal transition-all backdrop-blur-sm"
          />
        </div>
      </div>

      <a href="/admin/category/add" class="bg-teal-primary text-white px-6 py-2.5 rounded-2xl hover:bg-teal-700 transition-all font-bold shadow-lg shadow-teal-900/40 flex items-center justify-center gap-2 active:scale-95">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        Add New
      </a>
    </div>
  </div> 


   

        




  <!-- <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4  gap-6"> -->
<div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">

    <% if (categories && categories.length > 0) { %>
      <% categories.forEach((cat,i) => { %>

        <div class="category-card group bg-white rounded-lg shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden transition-all duration-300 hover:-translate-y-2">
          
          <div class="relative h-48 overflow-hidden">
            <% if (cat.image) { %>
              <a href="/admin/category/view/<%= cat.id %>">
                <img
                  src="/uploads/<%= cat.image %>"
                  alt="<%= cat.category %>"
                  class="category-image w-full h-full object-cover transition-transform duration-500"
                >
              </a>
            <% } else { %>
              <div class="w-full h-full bg-slate-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-slate-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            <% } %>

            <a href="#"  data-id="<%=cat.id%>"
              class="deleteBtn absolute top-4 right-4 p-2 bg-white/90 backdrop-blur
          shadow-lg rounded-xl text-slate-400 hover:text-red-600
          opacity-0 group-hover:opacity-100 transition-all duration-300"
   title="Delete">  <svg xmlns="http://www.w3.org/2000/svg"
       class="h-4 w-4"
       fill="none"
       viewBox="0 0 24 24"
       stroke="currentColor">
    <path stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12" />
  </svg>
              
            </a>
          </div>

          <div class="p-6">
            <div class="flex justify-between items-start mb-2">
              <h2 class="text-xl font-bold text-slate-800 tracking-tight"><%= cat.category %></h2>
              <span class="text-[10px] font-mono font-black text-slate-300 bg-slate-50 px-2 py-0.5 rounded">#<%= i+1 %></span>
            </div>

           

            <div class="mt-6 pt-4 border-t border-slate-50 flex justify-between items-center">
              <a href="/admin/category/<%= cat.id %>/sub/add" class="flex items-center gap-1.5 text-[10px] font-black text-teal-600 uppercase tracking-widest hover:text-teal-700 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                Add Sub
              </a>

              <a href="/admin/category/edit/<%= cat.id %>" class="p-2 bg-slate-50 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded-xl transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                </svg>
              </a>
            </div>
          </div>
        </div>

      <% }) %>
    <% } else { %>
      <div class="col-span-full py-20 text-center">
        <div class="text-slate-300 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">No Categories in Registry</p>
      </div>
    <% } %>

  </div>

  <div id="noCatResults" class="hidden py-20 text-center">
     <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">No matching categories found.</p>
  </div>

  <!---pagination-->

  <%if(totalPages>1){%>
<div class="flex justify-center items-center gap-2 py-10">


  <!--prev button-->
  <%if(currentPage>1){%>
      <a href="/admin/category/categoryList?page=<%=currentPage -1 %>"  class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">Prev</a>

 <% }%>

 <!--page number-->
 <%for(let i=1;i<=totalPages;i++){%>
   <a href="/admin/category/categoryList?page=<%=i%>"class="px-4 py-2 rounded-xl text-sm font-bold
         <%= i === currentPage 
            ? 'bg-teal-600 text-white' 
            : 'bg-slate-100 text-slate-600 hover:bg-teal-100' %>"><%=i%></a>

 <%}%>


 <!--next button-->
 <%if(currentPage< totalPages){%>
      <a href="/admin/category/categoryList?page=<%=currentPage+1%>" class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">Next</a>

 <%}%>
</div>
  <%}%>


  <div class="mt-16 border-t border-slate-100 pt-8 flex justify-center">
    <a href="/admin/dashboard" class="flex items-center gap-2 text-[11px] font-black text-slate-400 hover:text-teal-600 transition-all uppercase tracking-[0.2em]">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Return to Dashboard
    </a>
  </div>

</div>
</main>
<!-- DELETE MODAL -->
<div id="deleteModal"
     class="fixed inset-0 bg-black/40 backdrop-blur-sm
            flex items-center justify-center
            hidden z-50">

  <div class="bg-white rounded-2xl p-6 w-full max-w-md shadow-2xl">

    <h2 class="text-lg font-bold text-slate-800 mb-2">
      Delete Category?
    </h2>

    <p class="text-sm text-slate-500 mb-6">
      Are you sure you want to delete this category?
      
    </p>

    <div class="flex justify-end gap-3">
      <button id="cancelDelete"
              class="px-5 py-2 rounded-xl text-sm font-bold
                     bg-slate-100 text-slate-600 hover:bg-slate-200">
        Cancel
      </button>

      <a id="confirmDelete"
         href="#"
         class="px-5 py-2 rounded-xl text-sm font-bold
                bg-red-600 text-white hover:bg-red-700">
        Delete
      </a>
    </div>

  </div>
</div>
<script>
  //=============delete modal script=====================//
  const deleteModal=document.getElementById('deleteModal')
  const confirmDelete=document.getElementById('confirmDelete')
 const cancelDelete=document.getElementById('cancelDelete')
 const deleteBtn=document.querySelectorAll('.deleteBtn')

 let deletedId=null
 deleteBtn.forEach(btn=>{
  btn.addEventListener('click',function(){
deletedId=this.dataset.id;
confirmDelete.href=`/admin/category/delete/${deletedId}`
deleteModal.classList.remove('hidden')
  })
 })
 // Cancel delete
cancelDelete.addEventListener("click", () => {
  deleteModal.classList.add("hidden");
  deleteId = null;
});
// Close modal when clicking outside
deleteModal.addEventListener("click", (e) => {
  if (e.target === deleteModal) {
    deleteModal.classList.add("hidden");
    deleteId = null;
  }
});
</script>
<script>
  const searchCat = document.getElementById("searchCategory");
  const cards = document.querySelectorAll(".category-card");
  const noCatResults = document.getElementById("noCatResults");

  searchCat.addEventListener("input", () => {
    const query = searchCat.value.toLowerCase();
    let visibleCount = 0;

    cards.forEach(card => {
      const text = card.innerText.toLowerCase();
      const match = text.includes(query);
      card.style.display = match ? "block" : "none";
      if (match) visibleCount++;
    });

    noCatResults.style.display = visibleCount === 0 ? "block" : "none";
  });
</script>

</body>
</html> 