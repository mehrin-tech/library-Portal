
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Issue Book | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-50 min-h-screen flex items-center justify-center p-3 md:p-6 font-sans">

  <!-- CARD -->
  <div class="bg-white shadow-xl rounded-2xl md:rounded-[2rem] p-4 md:p-8 w-full max-w-lg border border-slate-100">

    <!-- TITLE -->
    <div class="text-center mb-6 md:mb-8">
      <h2 class="text-lg md:text-2xl font-black text-slate-800">
        Issue <span class="text-teal-600">Book</span>
      </h2>
    </div>

    <!-- FORM -->
    <form method="POST" class="space-y-4 md:space-y-5">

      <!-- STUDENT -->
      <div class="bg-slate-50 p-3 md:p-4 rounded-xl border">
        <label class="text-[10px] md:text-[11px] font-semibold text-slate-500 uppercase mb-2 block">
          Assign To Student
        </label>

        <select name="studentId" required
          class="w-full px-3 md:px-4 py-2 bg-white border rounded-lg text-sm focus:ring-2 focus:ring-teal-500">
          <option value="">-- Choose Borrower --</option>
          <% students.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.username %></option>
          <% }) %>
        </select>
      </div>

      <!-- BOOK -->
      <div class="bg-slate-50 p-3 md:p-4 rounded-xl border">
        <label class="text-[10px] md:text-[11px] font-semibold text-slate-500 uppercase mb-2 block">
          Select Book
        </label>

        <select name="bookId" required
          class="w-full px-3 md:px-4 py-2 bg-white border rounded-lg text-sm focus:ring-2 focus:ring-teal-500">
          <option value="">-- Choose Book --</option>
          <% books.forEach(b => { %>
            <option value="<%= b.id %>" <%= b.availableCopies <= 0 ? 'disabled' : '' %>>
              <%= b.title %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- DATE -->
      <div>
        <label class="text-[10px] md:text-[11px] font-semibold text-slate-500 uppercase mb-2 block">
          Return Date
        </label>

        <input type="date" name="returnDate" required
          class="w-full px-3 md:px-4 py-2 bg-slate-50 border rounded-lg text-sm focus:ring-2 focus:ring-teal-500">
      </div>

      <!-- BUTTON -->
      <div class="pt-3 md:pt-4 border-t">

        <button type="submit"
          class="w-full bg-teal-600 text-white py-2 md:py-3 rounded-xl text-sm font-bold hover:bg-teal-700">
          Confirm Issue
        </button>

        <a href="/admin/dashboard"
           class="block text-center mt-3 text-xs md:text-sm font-bold text-teal-600">
          ← Back to Dashboard
        </a>

      </div>

    </form>
  </div>

</body>
</html>
