<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Issue Book | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary-teal: #008080;
      --dark-teal: #004D4D;
    }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
    .focus-ring-teal:focus { 
      --tw-ring-color: var(--primary-teal); 
      border-color: var(--primary-teal); 
    }
    /* Custom Dropdown Arrow */
    select {
      background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
      background-position: right 0.5rem center;
      background-repeat: no-repeat;
      background-size: 1.5em 1.5em;
      appearance: none;
    }
  </style>
</head>

<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6 font-sans">
<div class="mt-6">
  <a href="/admin/dashboard"
     class="inline-flex items-center gap-2 text-sm font-bold text-teal-600
            hover:text-teal-800 transition-colors duration-200">
    <span class="text-lg leading-none">←</span>
    <span>Back to Dashboard</span>
  </a>
</div>

  <div class="bg-white shadow-2xl shadow-teal-900/10 rounded-[2.5rem] p-10 w-full max-w-xl border border-slate-100 relative overflow-hidden">
    
    <div class="absolute top-0 left-0 w-full h-2 bg-teal-primary"></div>

    <div class="text-center mb-10">
    
      <h2 class="text-3xl font-black text-slate-800 tracking-tight">Issue <span class="text-teal-600">Item</span></h2>
    </div>

    <form method="POST" class="space-y-6">

      <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
        <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-3 ml-1 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          Assign To Student
        </label>
        <select name="studentId" required
          class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus-ring-teal transition-all cursor-pointer">
          <option value="">-- Choose Borrower --</option>
          <% students.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.username %> (ID: <%= s.rollNo %>)</option>
          <% }) %>
        </select>
      </div>

      <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
        <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-3 ml-1 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          Select Book 
        </label>
        <select name="bookId" required
          class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus-ring-teal transition-all cursor-pointer">
          <option value="">-- Choose Book --</option>
          <% books.forEach(b => { %>
            <option value="<%= b.id %>" <%= b.quantity <= 0 ? 'disabled' : '' %>>
              <%= b.bookname %> <%= b.quantity <= 0 ? '(Out of Stock)' : '(Available: ' + b.quantity + ')' %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="flex flex-col md:flex-row md:items-center gap-4">
        <div class="flex-1">
          <label class="block text-[11px] font-black text-slate-500 uppercase tracking-widest mb-2 ml-1">Expected Return Date</label>
          <input type="date" name="returnDate" required
            class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus-ring-teal focus:bg-white transition-all">
        </div>
       
      </div>

      <div class="pt-6 border-t border-slate-50">
        <button type="submit"
          class="w-full bg-teal-primary text-white py-4 rounded-2xl hover:bg-teal-700 transition-all font-bold shadow-lg shadow-teal-900/20 active:scale-[0.98] flex items-center justify-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
            <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
          </svg>
          Confirm Issue
        </button>
        <p class="text-center mt-4">
          <a href="/admin/issued-list" class="text-[11px] font-black text-slate-400 hover:text-teal-600 transition-colors uppercase tracking-widest">
            View Active Issues
          </a>
        </p>

      </div>

    </form>
 

  </div>

  
 
</body>
</html>