<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= b.title%> Details | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary-teal: #008080;
    }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
    .border-teal-soft { border-color: rgba(0, 128, 128, 0.1); }
  </style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-3 md:p-6 font-sans">

  <div class="bg-white shadow-2xl rounded-2xl md:rounded-[3rem] 
              p-4 md:p-10 w-full max-w-4xl border flex flex-col md:flex-row gap-6 md:gap-12 relative">

    <div class="absolute top-0 left-0 w-full h-2 bg-teal-primary"></div>

    <!-- IMAGE -->
    <div class="flex-shrink-0 flex flex-col items-center gap-4 md:gap-6">

      <div class="relative group">
        <img
          src="<%= b.image %>"
          class="w-40 md:w-64 h-auto rounded-2xl shadow-lg object-cover"
        />

        <div class="absolute top-2 md:top-4 right-2 md:right-4">
          <% if (b.availableCopies > 0) { %>
            <span class="bg-green-500 text-white text-[9px] md:text-[10px] px-2 md:px-3 py-1 rounded-full">
              In Stock
            </span>
          <% } else { %>
            <span class="bg-red-500 text-white text-[9px] md:text-[10px] px-2 md:px-3 py-1 rounded-full">
              Out
            </span>
          <% } %>
        </div>

      </div>

    </div>

    <!-- CONTENT -->
    <div class="flex-1">

      <h1 class="text-2xl md:text-4xl font-black mb-2">
        <%= b.bookname %>
      </h1>

      <p class="text-xs md:text-sm text-teal-600 mb-4">
        Full Publication Data
      </p>

      <!-- DETAILS -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4">

        <div class="bg-slate-50 p-3 md:p-4 rounded-xl">
          <p class="text-[9px] text-slate-400">Author</p>
          <p class="text-sm font-bold"><%= b.author %></p>
        </div>

        <div class="bg-slate-50 p-3 md:p-4 rounded-xl">
          <p class="text-[9px] text-slate-400">ISBN</p>
          <p class="text-sm font-bold"><%= b.isbn %></p>
        </div>

        <div class="bg-slate-50 p-3 md:p-4 rounded-xl">
          <p class="text-[9px] text-slate-400">Copies</p>
          <p class="text-sm font-bold">
            <%= b.availableCopies %> / <%= b.totalCopies %>
          </p>
        </div>

        <div class="bg-slate-50 p-3 md:p-4 rounded-xl">
          <p class="text-[9px] text-slate-400">Date</p>
          <p class="text-sm font-bold">
            <%= new Date(b.createdAt).toLocaleDateString() %>
          </p>
        </div>

      </div>

      <!-- FOOTER -->
      <div class="mt-6 md:mt-10 flex flex-col md:flex-row gap-3 md:justify-between">

        <a href="/admin/booksList"
           class="text-xs text-slate-500 hover:text-teal-600">
          ← Back
        </a>

        <a href="/admin/issue-book"
           class="bg-teal-primary text-white px-5 md:px-8 py-2 md:py-3 rounded-xl text-sm text-center">
          Issue Book
        </a>

      </div>

    </div>

  </div>

</body>
</html>