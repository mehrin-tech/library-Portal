<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Issue Record | Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-50 min-h-screen font-sans text-slate-900">
<%- include('../partials/adminSidebar') %>

<main class="ml-20 p-8">
  <div class="max-w-6xl mx-auto">

    <!-- HEADER -->
    <div class="flex items-center justify-between mb-10">
      <h1 class="text-3xl font-black tracking-tight">
        Issue <span class="text-teal-600">Record</span>
      </h1>

      <a href="/admin/issue-book"
         class="inline-flex items-center gap-2 px-6 py-3 rounded-2xl
                bg-teal-600 text-white font-black text-xs uppercase tracking-widest
                hover:bg-teal-700 transition shadow-lg">
        + New Issue
      </a>
    </div>

    <!-- CARD -->
    <div class="bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">

      <!-- TABLE -->
      <div class="overflow-x-auto mt-6">
        <table class="w-full">
          
          <!-- TABLE HEADER -->
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="px-8 py-5 text-left text-xs font-black text-slate-400 uppercase tracking-widest">
                Borrower
              </th>
              <th class="px-8 py-5 text-left text-xs font-black text-slate-400 uppercase tracking-widest">
                Book Title
              </th>
              <th class="px-8 py-5 text-left text-xs font-black text-slate-400 uppercase tracking-widest">
                Status
              </th>
              <th class="px-8 py-5 text-right text-xs font-black text-slate-400 uppercase tracking-widest">
                Fine
              </th>
              <th class="px-8 py-5 text-left text-xs font-black text-slate-400 uppercase tracking-widest">
                Payment
              </th>
              <th class="px-8 py-5 text-right text-xs font-black text-slate-400 uppercase tracking-widest">
                Management
              </th>
            </tr>
          </thead>

          <!-- TABLE BODY -->
          <tbody class="divide-y divide-slate-100">
            <% issued.forEach(i => { %>
              <tr class="hover:bg-teal-50/40 transition">

                <!-- Borrower -->
                <td class="px-8 py-6">
                  <p class="text-sm font-semibold text-slate-700">
                    <%= i.student.username %>
                  </p>
                </td>

                <!-- Book -->
                <td class="px-8 py-6">
                  <p class="text-sm font-semibold text-slate-600">
                    <%= i.book.title %>
                  </p>
                </td>

                <!-- Status -->
                <td class="px-8 py-6">
                  <% if (i.status === "issued") { %>
                    <span class="inline-flex items-center gap-2 px-3 py-1
                                 text-[10px]  font-semibold uppercase tracking-widest
                                 text-amber-700 bg-amber-100 rounded-full">
                      <span class="w-1.5 h-1.5 bg-amber-600 rounded-full"></span>
                      Issued
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center gap-2 px-3 py-1
                                 text-[10px]  font-semibold uppercase tracking-widest
                                 text-emerald-700 bg-emerald-100 rounded-full">
                      <span class="w-1.5 h-1.5 bg-emerald-600 rounded-full"></span>
                      Returned
                    </span>
                  <% } %>
                </td>

                <!-- Fine -->
                <td class="px-8 py-6 text-right">
                  <% if (i.fine > 0) { %>
                    <p class="font-semibold text-slate-700">
                      ₹<%= i.fine %>
                      <span class="block text-[10px] text-slate-400">
                        (<%= i.lateDays %> days late)
                      </span>
                    </p>
                  <% } else { %>
                    <span class="text-xs font-semibold text-emerald-600">No Fine</span>
                  <% } %>
                </td>

                <!-- Payment -->
                <td class="px-8 py-6">
                  <% if (i.fine > 0 && !i.finePaid) { %>
                    <span class="text-[11px] font-black font-semibold text-rose-600 uppercase">
                      ❌ Not Paid
                    </span>
                  <% } else if (i.finePaid) { %>
                    <span class="text-[11px] font-black font-semibold text-emerald-600 uppercase">
                      ✅ Paid
                    </span>
                  <% } %>
                </td>

                <!-- Management -->
                <td class="px-8 py-6 text-right">
                  <% if (i.status === "issued") { %>
                    <form method="POST" action="/admin/return-book/<%= i.id %>">
                      <button type="submit"
                        class="px-4 py-2 rounded-xl text-xs font-black font-semibold uppercase tracking-widest
                               border border-teal-200 text-teal-600
                               hover:bg-teal-600 hover:text-white transition">
                        Mark Returned
                      </button>
                    </form>
                  <% } else { %>
                    <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest">
                      Settled
                    </span>
                  <% } %>
                </td>

              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- EMPTY STATE -->
      <% if (issued.length === 0) { %>
        <div class="py-20 text-center">
          <p class="text-slate-400 text-sm font-black uppercase tracking-widest">
            No active loans found
          </p>
        </div>
      <% } %>

    </div>
  </div>
</main>

</body>
</html>
