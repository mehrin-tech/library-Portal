<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Issue Record | Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>

  
</head>

<body class="bg-slate-50 min-h-screen font-sans text-slate-900">

<%- include('../partials/adminSidebar') %>

<main class="ml-0 md:ml-20 p-3 md:p-8">
  <div class="max-w-6xl mx-auto">

    <!-- HEADER -->
    <div class="flex flex-col md:flex-row gap-4 md:items-center justify-between mb-6 md:mb-10">

      <h1 class="text-xl md:text-3xl font-black">
        Issue <span class="text-teal-600">Record</span>
      </h1>

      <a href="/admin/issue-book"
         class="w-full md:w-auto text-center px-4 md:px-6 py-2 md:py-3 rounded-xl md:rounded-2xl
                bg-teal-600 text-white text-xs font-bold">
        + New Issue
      </a>
    </div>

    <!-- CARD -->
    <div class="bg-white rounded-2xl md:rounded-3xl shadow-xl border overflow-hidden">

      <!-- TABLE -->
      <div class="overflow-x-auto">
        <table class="w-full text-xs md:text-sm">

          <thead class="bg-slate-50">
            <tr>
              <th class="px-3 md:px-8 py-3 text-left">Borrower</th>
              <th class="px-3 md:px-8 py-3 text-left">Book</th>
              <th class="px-3 md:px-8 py-3 text-left">Status</th>
              <th class="px-3 md:px-8 py-3 text-right">Fine</th>
              <th class="px-3 md:px-8 py-3 text-left">Payment</th>
              <th class="px-3 md:px-8 py-3 text-right">Action</th>
            </tr>
          </thead>

          <tbody>
            <% issued.forEach(i => { %>

            <tr class="hover:bg-teal-50">

              <td class="px-3 md:px-8 py-3 font-semibold">
                <%= i.student.username %>
              </td>

              <td class="px-3 md:px-8 py-3">
                <%= i.book.title %>
              </td>

              <td class="px-3 md:px-8 py-3">
                <span class="text-xs px-2 py-1 rounded-full
                  <%= i.status==='issued' ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-600' %>">
                  <%= i.status %>
                </span>
              </td>

              <td class="px-3 md:px-8 py-3 text-right">
                ₹<%= i.fine %>
              </td>

              <td class="px-3 md:px-8 py-3 text-xs">
                <%= i.finePaid ? 'Paid' : 'Not Paid' %>
              </td>

              <td class="px-3 md:px-8 py-3 text-right">
                <% if(i.status==='issued'){ %>
                  <form method="POST" action="/admin/return-book/<%= i.id %>">
                    <button class="px-2 md:px-4 py-1 md:py-2 text-xs bg-teal-600 text-white rounded-lg">
                      Return
                    </button>
                  </form>
                <% } %>
              </td>

            </tr>

            <% }) %>
          </tbody>

        </table>
      </div>

    </div>

    <!-- PAGINATION -->
    <div class="flex flex-wrap justify-center gap-2 mt-6">

      <% if(currentPage>1){ %>
        <a href="?page=<%=currentPage-1%>" class="px-3 py-1 bg-slate-100 rounded">Prev</a>
      <% } %>

      <% for(let i=1;i<=totalPages;i++){ %>
        <a href="?page=<%=i%>" class="px-3 py-1 rounded
        <%= i===currentPage ? 'bg-teal-600 text-white' : 'bg-slate-100' %>">
        <%=i%></a>
      <% } %>

      <% if(currentPage<totalPages){ %>
        <a href="?page=<%=currentPage+1%>" class="px-3 py-1 bg-slate-100 rounded">Next</a>
      <% } %>

    </div>

  </div>
</main>

</body>
</html>
