<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Issued Books | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary-teal: #008080;
      --dark-teal: #004D4D;
    }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
    .border-teal-soft { border-color: rgba(0, 128, 128, 0.1); }
  </style>
</head>

<body class="bg-slate-50 min-h-screen p-8 font-sans">
<%-include ('../partials/adminSidebar')%>
<main class="ml-20 p-8">
  <div class="max-w-7xl mx-auto bg-white shadow-2xl shadow-teal-900/5 rounded-[2.5rem] overflow-hidden border border-slate-100">

    <div class="px-10 py-8 border-b border-slate-50 flex flex-col md:flex-row md:items-center justify-between gap-6 bg-white">
      <div>
        <h1 class="text-3xl font-black text-slate-800 tracking-tight">
          Issue<span class="text-teal-600">Record</span>
        </h1>
        <p class="text-[11px] text-slate-400 font-black uppercase tracking-[0.2em] mt-1">Track issue & returns</p>
      </div>

      <div class="flex items-center gap-3">
        <a href="/admin/issue-book" class="flex items-center gap-2 bg-teal-primary text-white px-6 py-3 rounded-2xl hover:bg-teal-700 transition-all shadow-lg shadow-teal-900/10 font-bold text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          New Issue
        </a>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-slate-50/50">
            <th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Borrower</th>
            <th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Book Title</th>
            <th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Status</th>
            <th class="px-8 py-4 text-right text-[10px] font-black text-slate-400 uppercase tracking-widest">Fine</th>
           <th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">
  Payment
</th>
<th class="px-8 py-4 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">
  Management
</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-slate-50">
          <% issued.forEach(i => { %>
            <%let delayDays=0
            if(i.actualReturnDate && i.actualReturnDate>i.returnDate){
              const due=new Date(i.returnDate);
              const returned=new Date(i.actualReturnDate)
              delayDays=Math.ceil((returned-due)/(1000*60*60*24))
            }%>
            <tr class="group hover:bg-teal-50/30 transition-colors">

              <td class="px-8 py-5">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-slate-700">
                      <%= students.find(s => s.id === i.studentId).username %>
                    </p>
                    <p class="text-[10px] font-bold text-slate-400 uppercase">Member ID: #<%= i.studentId %></p>
                  </div>
                </div>
              </td>

              <td class="px-8 py-5">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center text-teal-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                  </div>
                  <p class="text-sm font-medium text-slate-600">
                    <%= books.find(b => b.id === i.bookId).bookname %>
                  </p>
                </div>
              </td>

              <td class="px-8 py-5">
                <% if (i.status === "issued") { %>
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 text-[10px] font-black uppercase tracking-wider text-amber-700 bg-amber-100 rounded-full border border-amber-200">
                    <span class="w-1 h-1 rounded-full bg-amber-600"></span>
                    Issued
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 text-[10px] font-black uppercase tracking-wider text-emerald-700 bg-emerald-100 rounded-full border border-emerald-200">
                    <span class="w-1 h-1 rounded-full bg-emerald-600"></span>
                    Returned
                  </span>
                <% } %>
              </td>

              
              <td  class="px-8 py-5">
                <%if(i.fine >0){%>
                  <p>
                     ₹<%= i.fine %>
                     <span class="block text-[10px] text-slate-400">
        (<%= delayDays %> days late)
      </span>
                  </p>

               <% }else{%>
                    <span class="text-xs font-bold text-emerald-600">No Fine</span>

              <% }%>
              </td>
              <td class="px-8 py-5 text-right">

  <% if (i.fine > 0 && i.finePaid === false) { %>
    <span class="inline-flex items-center gap-2 text-[11px] font-black text-rose-600 uppercase mb-2">
      ❌ Not Paid
    </span>
<!-- 
     <form method="POST" action="/admin/mark-fine-paid/<%= i.id %>">
      <button type="submit"
        class="mt-2 px-4 py-2 rounded-xl text-xs font-black uppercase
        bg-rose-100 text-rose-600 hover:bg-rose-600 hover:text-white transition">
        Mark Paid
      </button>
    </form>  -->


  <% } else if (i.fine > 0 && i.finePaid === true) { %>
    <span class="inline-flex items-center gap-2 text-[11px] font-black text-emerald-600 uppercase">
      ✅ Paid
    </span>
  <%}%>
              </td>
              <td class="px-8 py-5 text-right">
                <% if (i.status === "issued") { %>
                  <form method="POST" action="/admin/return-book/<%= i.id %>">
                    <button type="submit" class="inline-flex items-center gap-2 bg-white border border-teal-200 text-teal-600 px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-teal-primary hover:text-white hover:border-teal-primary transition-all shadow-sm">
                      Mark Returned
                    </button>
                  </form>
                <% } else { %>
                  <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest italic">Settled</span>
                <% } %>
              </td>

            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (issued.length === 0) { %>
      <div class="py-20 text-center">
        <p class="text-slate-400 text-sm font-bold uppercase tracking-widest">No active loans found</p>
      </div>
    <% } %>

  </div>

   <!---pagination-->
  <%if(totalPages>1){%>
      <div class="flex justify-center items-center gap-2 py-10">

        <!--prev button-->
        <%if(currentPage>1){%>
                <a href="/admin/issued-list?page=<%=currentPage -1 %>"  class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">Prev</a>


       <% }%>

       <!--pageNumber-->

       <%for(let i=1;i<=totalPages;i++){%>
         <a href="/admin/issued-list?page=<%=i%>"class="px-4 py-2 rounded-xl text-sm font-bold
         <%= i === currentPage 
            ? 'bg-teal-600 text-white' 
            : 'bg-slate-100 text-slate-600 hover:bg-teal-100' %>"><%=i%></a>

       <%}%>

       <!--next button-->
       <%if(currentPage < totalPages){%>
    <a href="/admin/issued-list?page=<%=currentPage+1%>" class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">Next</a>

       <%}%>

  <%}%>
      </div>
      </main>
       
</body>
</html>