 <!---signup modal-->
  <div id="overlay" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm hidden z-50 flex items-center justify-center p-6">
    <div id="signupModal" class="bg-white rounded-3xl w-full max-w-md p-10 relative shadow-2xl border-t-8 border-teal-primary">
      <div class="mb-8 flex justify-between items-start">
        <div>
          <h2 class="text-2xl font-extrabold text-slate-800">Create Account</h2>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mt-1">Join the community</p>
        </div>
        <button id="closeModal" class="text-slate-300 hover:text-rose-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

     
     
<form action="/User/signup" method="POST" enctype="multipart/form-data" class="space-y-4">

  <!-- First & Last Name -->
  <div class="grid grid-cols-2 gap-3">
    <input
      type="text"
      name="firstname"
      placeholder="First Name"
      class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:ring-2 focus:ring-teal-500/20"
      required
    />
    <input
      type="text"
      name="lastname"
      placeholder="Last Name"
      class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:ring-2 focus:ring-teal-500/20"
      required
    />
  </div>

  <!-- Email -->
  <input
    type="email"
    name="email"
    placeholder="Email"
    class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:ring-2 focus:ring-teal-500/20"
    required
  />

  <!-- Password -->
  <input
    type="password"
    name="password"
    placeholder="Password"
    class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:ring-2 focus:ring-teal-500/20"
    required
  />

  <!-- Department & Semester -->
  <div class="grid grid-cols-2 gap-3">
    <select
      name="department"
      class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:ring-2 focus:ring-teal-500/20"
      required
    >
      <option value="" disabled selected>Select Department</option>

      <optgroup label="BSc">
        <option value="BSc_CS">Computer Science</option>
        <option value="BSc_Chemistry">Chemistry</option>
        <option value="BSc_Mathematics">Mathematics</option>
        <option value="BSc_Physics">Physics</option>
      </optgroup>

      <optgroup label="BA">
        <option value="BA_Sociology">Sociology</option>
        <option value="BA_English">English</option>
        <option value="BA_History">History</option>
      </optgroup>

      <optgroup label="BCom">
        <option value="BCom_General">BCom General</option>
        <option value="BCom_Cooperation">BCom Cooperation</option>
        <option value="BCom_Finance">BCom Finance</option>
      </optgroup>

      <optgroup label="BBA">
        <option value="BBA">Bachelor of Business Administration</option>
      </optgroup>
    </select>

    <select
      name="semester"
      class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:ring-2 focus:ring-teal-500/20"
      required
    >
      <option value="" disabled selected>Select Semester</option>
      <option value="1">Semester 1</option>
      <option value="2">Semester 2</option>
      <option value="3">Semester 3</option>
      <option value="4">Semester 4</option>
      <option value="5">Semester 5</option>
      <option value="6">Semester 6</option>
      <option value="7">Semester 7</option>
      <option value="8">Semester 8</option>
    </select>
  </div>

  <!-- Status & Image -->
  <div class="grid grid-cols-2 gap-3">
    <select
      name="status"
      class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:ring-2 focus:ring-teal-500/20"
      required
    >
      <option value="" disabled selected>Status</option>
      <option value="active">Active</option>
      <option value="inactive">Inactive</option>
    </select>

    <input
      type="file"
      name="image"
      accept="image/*"
      class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm outline-none focus:ring-2 focus:ring-teal-500/20"
    />
  </div>

  <!-- Submit -->
  <button
    type="submit"
    class="w-full btn-primary text-white py-4 rounded-xl font-extrabold uppercase text-[11px] tracking-widest"
  >
    Create Account
  </button>

</form>
</div>
</div>

  




   


 

 

  <script>
    const overlay = document.getElementById("overlay");
    const close = document.getElementById("closeModal");
    close.onclick = () => overlay.classList.add("hidden");
    window.onclick = (e) => { if (e.target === overlay) overlay.classList.add("hidden"); };
  </script>
  <script>
  const resourcesBtn = document.getElementById("resourcesBtn");
  const resourcesMenu = document.getElementById("resourcesMenu");

  resourcesBtn.addEventListener("click", () => {
    resourcesMenu.classList.toggle("hidden");
  });

  // Close dropdown when clicking outside
  window.addEventListener("click", (e) => {
    if (!resourcesBtn.contains(e.target) && !resourcesMenu.contains(e.target)) {
      resourcesMenu.classList.add("hidden");
    }
  });
</script>
