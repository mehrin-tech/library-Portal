     <!---FAQS section-->
<section id="faqs" class="bg-[#D6EEE6] py-24">
  <div class="max-w-4xl mx-auto px-6">

    <!-- Heading -->
    <div class="text-center mb-12">
     

      <h2 class="text-4xl font-extrabold text-slate-900 mb-4">
        Frequently <span class="text-[#2d8a75]">Asked Questions</span>
      </h2>
      
    </div>

    <!-- FAQ List -->
    <div class="space-y-4">

      <!-- FAQ Item -->
      <details class="group bg-white border border-slate-200 rounded-xl p-5 
                      hover:shadow-md transition">
        <summary class="flex justify-between items-center cursor-pointer font-semibold text-slate-800">
          How many books can I issue at a time?
          <span class="text-teal-600 group-open:rotate-180 transition-transform">⌄</span>
        </summary>
        <p class="mt-4 text-slate-500 leading-relaxed">
          Students can issue a limited number of books at a time according to the library policy.
        </p>
      </details>

      <details class="group bg-white border border-slate-200 rounded-xl p-5 
                      hover:shadow-md transition">
        <summary class="flex justify-between items-center cursor-pointer font-semibold text-slate-800">
          What happens if I return a book late?
          <span class="text-teal-600 group-open:rotate-180 transition-transform">⌄</span>
        </summary>
        <p class="mt-4 text-slate-500 leading-relaxed">
          Late returns may result in a fine based on the number of delayed days.
        </p>
      </details>

      <details class="group bg-white border border-slate-200 rounded-xl p-5 
                      hover:shadow-md transition">
        <summary class="flex justify-between items-center cursor-pointer font-semibold text-slate-800">
          How is the fine calculated?
          <span class="text-teal-600 group-open:rotate-180 transition-transform">⌄</span>
        </summary>
        <p class="mt-4 text-slate-500 leading-relaxed">
          The fine is calculated per day after the due date and must be cleared before issuing new books.
        </p>
      </details>

      <details class="group bg-white border border-slate-200 rounded-xl p-5 
                      hover:shadow-md transition">
        <summary class="flex justify-between items-center cursor-pointer font-semibold text-slate-800">
          Can I read books online?
          <span class="text-teal-600 group-open:rotate-180 transition-transform">⌄</span>
        </summary>
        <p class="mt-4 text-slate-500 leading-relaxed">
          Yes, students can read available e-books online through the library portal.
        </p>
      </details>

      <details class="group bg-white border border-slate-200 rounded-xl p-5 
                      hover:shadow-md transition">
        <summary class="flex justify-between items-center cursor-pointer font-semibold text-slate-800">
          Who can access the library?
          <span class="text-teal-600 group-open:rotate-180 transition-transform">⌄</span>
        </summary>
        <p class="mt-4 text-slate-500 leading-relaxed">
          Only registered students and authorized users are allowed to access library resources.
        </p>
      </details>

    </div>
  </div>
</section>


     




    



