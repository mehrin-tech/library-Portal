 <!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>College Library | Gateway</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-teal: #2d8a75;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }

    /* The "Network" node pattern from the reference image */
    .network-pattern {
      background-image: radial-gradient(circle, #2d8a75 1px, transparent 1px);
      background-size: 32px 32px;
      mask-image: radial-gradient(circle at center, black, transparent 80%);
      opacity: 0.15;
    }

    /* Modern button styling to match image */
    .btn-primary {
      background-color: var(--primary-teal);
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      background-color: #236e5d;
      transform: translateY(-2px);
    }
    
    .btn-outline {
      border: 1px solid #d1d5db;
      transition: all 0.3s ease;
    }
    .btn-outline:hover {
      background-color: #f9fafb;
      transform: translateY(-2px);
    }
    /* Job portal style hero background */
.hero-bg {
  background:
    radial-gradient(circle at 20% 30%, rgba(45,139,117,0.15), transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(45,139,117,0.12), transparent 45%),
    linear-gradient(to right, #f8fbfb, #ffffff);
}

/* Network dots */
.network-dots {
  background-image: radial-gradient(circle, rgba(45,139,117,0.35) 1px, transparent 1px);
  background-size: 26px 26px;
  opacity: 0.35;
}

/* Connecting lines illusion */
.network-lines {
  background-image:
    linear-gradient(120deg, rgba(45,139,117,0.15) 1px, transparent 1px),
    linear-gradient(60deg, rgba(45,139,117,0.15) 1px, transparent 1px);
  background-size: 120px 120px;
  opacity: 0.15;
}

    
  </style>
</head>

<body class="bg-white m-0 p-0  ">

