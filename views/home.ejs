<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>College Library | Gateway</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --primary-teal: #008080;
    }

    .bg-teal-primary {
      background-color: var(--primary-teal);
    }

    .text-teal-primary {
      color: var(--primary-teal);
    }

    .bg-main {
      background: radial-gradient(circle at top left, #f8fafc 0%, #e2e8f0 100%);
    }

    .teal-gradient-bg {
      background: linear-gradient(135deg, #008080 0%, #006666 100%);
    }
  </style>
</head>

<body class="bg-main m-0 p-0 h-screen overflow-hidden font-sans">

  <nav class="fixed top-0 left-0 w-full z-20 bg-white/80 backdrop-blur-md border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-8 py-4 flex justify-between items-center">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 bg-teal-primary rounded-lg flex items-center justify-center text-white text-lg shadow-lg">📚
        </div>
        <h1 class="text-xl font-black text-slate-800 tracking-tight uppercase">College <span
            class="text-teal-600">Library</span></h1>
      </div>

      <div class="flex gap-4">
        <%if(!isLoggedIn){%>
        <button onclick="document.getElementById('overlay').classList.remove('hidden')"
          class="text-[10px] font-black uppercase tracking-widest text-white bg-[#008080] hover:bg-[#006666] py-3 px-6 rounded-xl transition-all shadow-lg shadow-teal-900/20 active:scale-95">
          Create Account
        </button>
        <%}%>
       <% if (isLoggedIn) { %>
  <div class="flex items-center gap-3">
    <span class="text-md font-bold text-teal-600">
      <%= username %>
    </span>
      
<% } %>



        <!-- <button class="bg-rose-500 hover:bg-rose-600 text-white text-[10px] font-black uppercase tracking-widest py-2.5 px-6 rounded-xl shadow-lg transition-all active:scale-95">
          Exit Portal
        </button> -->
      </div>
    </div>
  </nav>

  <div class="relative h-screen flex items-center justify-center pt-20">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-teal-500/5 rounded-full blur-[120px] pointer-events-none">
    </div>

    <div class="relative z-10 max-w-2xl text-center px-8">
      <!-- <div class="inline-block px-4 py-1.5 bg-teal-50 border border-teal-100 rounded-full mb-6">
        <span class="text-[10px] font-black text-teal-600 uppercase tracking-[0.2em]">Academic Resource
          Management</span>
      </div> -->

      <h1 class="text-6xl font-black text-slate-900 mb-6 tracking-tighter leading-none">
        Knowledge <br />
        <span class="text-teal-600">Hub</span>
      </h1>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/User/login"
          class="teal-gradient-bg text-white font-black text-[11px] uppercase tracking-[0.2em] py-5 px-10 rounded-2xl shadow-2xl shadow-teal-900/20 hover:-translate-y-1 transition-all">
          Student Access
        </a>
        <a href="/admin/login"
          class="bg-white text-slate-700 border border-slate-200 font-black text-[11px] uppercase tracking-[0.2em] py-5 px-10 rounded-2xl shadow-xl hover:bg-slate-50 transition-all">
          Administrator
        </a>
      </div>
    </div>
  </div>

  <div id="overlay"
    class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden z-50 flex items-center justify-center p-6">
    <div id="signupModal"
      class="bg-white shadow-[0_32px_64px_-15px_rgba(0,0,0,0.3)] rounded-[2.5rem] w-full max-w-lg p-10 md:p-14 relative overflow-hidden transition-all transform">

      <div class="absolute top-0 left-0 w-full h-2 bg-teal-primary"></div>

      <div class="mb-8 flex justify-between items-start">
        <div>
          <h2 class="text-3xl font-black text-slate-800 tracking-tight leading-tight">Create <span
              class="text-teal-600">Account</span></h2>
          <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-2">Register for full library
            access</p>
        </div>
        <button id="closeModal" class="text-slate-300 hover:text-rose-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <form action="/User/signup" method="POST" class="grid grid-cols-2 gap-4">
        <input type="text" name="firstname" placeholder="First Name"
          class="col-span-1 p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-teal-500/20"
          required />
        <input type="text" name="lastname" placeholder="Last Name"
          class="col-span-1 p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-teal-500/20"
          required />
        <input type="email" name="email" placeholder="Email"
          class="col-span-2 p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-teal-500/20"
          required />
        <input type="text" name="number" placeholder="Contact"
          class="col-span-1 p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-teal-500/20"
          required />
        <div class="col-span-1 relative">
          <input type="date" name="Dob"
            class="w-full p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm text-slate-500 focus:outline-none focus:ring-2 focus:ring-teal-500/20"
            required />
          <span
            class="absolute -top-2 left-3 bg-white px-1 text-[8px] font-black text-slate-400 uppercase tracking-widest">Birth
            Date</span>
        </div>
        <input type="password" name="password" placeholder="Secure Password"
          class="col-span-2 p-4 bg-slate-50 border border-slate-100 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-teal-500/20"
          required />

        <button type="submit"
          class="col-span-2 mt-4 bg-teal-primary text-white py-5 rounded-2xl font-black text-[11px] uppercase tracking-[0.2em] shadow-xl shadow-teal-900/20 hover:bg-teal-700 transition-all active:scale-95">
          Create Account
        </button>
      </form>

      <p class="text-center mt-6 text-[10px] font-bold text-slate-400 uppercase tracking-widest">
        Existing Member? <a href="/User/login" class="text-teal-600 hover:underline">Sign In </a>
      </p>
    </div>
  </div>

  <script>
    const overlay = document.getElementById("overlay");
    const close = document.getElementById("closeModal");

    close.onclick = () => overlay.classList.add("hidden");
    window.onclick = (e) => { if (e.target === overlay) overlay.classList.add("hidden"); };
    document.onkeydown = (e) => { if (e.key === "Escape") overlay.classList.add("hidden"); };
    
 
 
        

      



  const bookSearch = document.getElementById('searchInp')
  const rows = document.querySelectorAll('.book-row')
</script>
</body>

</html>