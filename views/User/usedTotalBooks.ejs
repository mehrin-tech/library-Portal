<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reading History | Student Portal</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>
:root { --primary-teal: #008080; }
.bg-teal-primary { background-color: var(--primary-teal); }
.scrollbar-hide::-webkit-scrollbar { display: none; }
</style>

</head>

<body class="bg-slate-50 min-h-screen font-sans">

<%- include('../partials/userSidebar') %>

<main class="ml-20 p-8">

<!-- HEADER -->
<header class="flex justify-between items-center mb-10">

<div>
<h1 class="text-3xl font-black text-slate-800">
Read <span class="text-[#2d8a75]">Books List</span>
</h1>
</div>

<div class="bg-white px-6 py-3 rounded-2xl border shadow-sm">
<p class="text-xs font-bold text-slate-400 uppercase">Total Books</p>
<p class="text-lg font-bold"><%= usedBooks.length %></p>
</div>

</header>

<!-- TABLE -->
<div class="bg-white rounded-3xl shadow-xl border overflow-hidden">

<div class="overflow-x-auto scrollbar-hide">

<table class="w-full">

<thead class="bg-slate-50">
<tr>
  <th class="px-8 py-5 text-left text-xs uppercase text-slate-400">ID</th>

<th class="px-8 py-5 text-left text-xs uppercase text-slate-400">Title</th>
<th class="px-8 py-5 text-center text-xs uppercase text-slate-400">Issue Date</th>
<th class="px-8 py-5 text-center text-xs uppercase text-slate-400">Return Date</th>
<th class="px-8 py-5 text-right text-xs uppercase text-slate-400">Status</th>
</tr>
</thead>

<tbody>

<!-- EMPTY STATE -->
<% if (usedBooks.length === 0) { %>

<tr>
<td colspan="4" class="text-center py-20 text-slate-400">
No history found
</td>
</tr>

<% } %>

<!-- BOOK LIST -->
<% usedBooks.forEach((i,index) => { %>

<tr class="border-t hover:bg-slate-50 transition">

  <td>
    <span class="px-8 py-6 text-center text-sm font-semibold text-slate-600">
ID: <%= i.book ? index+1 : '' %>
</span>
  </td>
<!-- BOOK -->
<td class="px-8 py-6">
<div class="flex flex-col">

<span class="font-bold text-slate-800">
<%= i.book ? i.book.title : 'Removed Book' %>
</span>



</div>
</td>

<!-- ISSUE DATE -->
<td class="px-8 py-6 text-center text-sm font-semibold text-slate-600">
<%= i.issueDate ? new Date(i.issueDate).toLocaleDateString() : '—' %>
</td>

<!-- RETURN DATE -->
<td class="px-8 py-6 text-center text-sm font-semibold text-slate-600">
<%= i.actualReturnDate ? new Date(i.actualReturnDate).toLocaleDateString() : '—' %>
</td>

<!-- STATUS -->
<td class="px-8 py-6 text-right">

<% if (i.status === 'issued') { %>

<span class="px-3 py-1 text-xs font-bold rounded-full bg-blue-100 text-blue-600">
Borrowed
</span>

<% } else { %>

<span class="px-3 py-1 text-xs font-bold rounded-full bg-emerald-100 text-emerald-600">
Returned
</span>

<% } %>

</td>

</tr>

<% }) %>

</tbody>

</table>
</div>
</div>

<!-- PAGINATION -->
<div class="flex justify-between mt-8">

<p class="text-xs text-slate-400">
Page <%= currentPage %> of <%= totalPages %>
</p>

<div class="flex gap-2">

<% if (currentPage > 1) { %>
<a href="?page=<%= currentPage-1 %>"
class="px-4 py-2 border rounded-lg text-sm hover:bg-teal-50">
Prev
</a>
<% } %>

<% if (currentPage < totalPages) { %>
<a href="?page=<%= currentPage+1 %>"
class="px-4 py-2 border rounded-lg text-sm hover:bg-teal-50">
Next
</a>
<% } %>

</div>

</div>

</main>
</body>
</html>
