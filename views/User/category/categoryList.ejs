<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Category Registry | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- <style>
    :root { --primary-teal: #008080; }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
    .category-card:hover .category-image { transform: scale(1.05); }
    .focus-ring-teal:focus { --tw-ring-color: var(--primary-teal); border-color: var(--primary-teal); }
  </style> -->
</head>

<body class="bg-slate-50 min-h-screen font-sans">

<!-- Sidebar -->
 <%- include('../../partials/userSidebar') %> 


<!-- Header -->
<header class="ml-20 bg-white border-b border-slate-100 sticky top-0 z-40">
  <div class="px-8 py-5 flex justify-between items-center">

    <div>
      <h1 class="text-2xl font-bold text-slate-800">
        Category <span class="text-teal-600">Collection</span>
      </h1>
     
    </div>

    <!-- Search -->
    <div class="w-80 relative">
      <input
        type="text"
        id="searchCategory"
        placeholder="Search category..."
        class="w-full pl-10 pr-4 py-2.5 text-sm rounded-lg border border-slate-200 focus:border-teal-600 focus:ring-2 focus:ring-teal-100 outline-none"
      />

      <svg xmlns="http://www.w3.org/2000/svg"
           class="absolute left-3 top-3.5 h-4 w-4 text-slate-400"
           fill="none"
           viewBox="0 0 24 24"
           stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M21 21l-4.3-4.3m1.8-4.2a6 6 0 11-12 0 6 6 0 0112 0z"/>
      </svg>

    </div>

  </div>
</header>


<!-- Main -->
<main class="ml-20 p-8 overflow-hidden">

  <div class="max-w-7xl mx-auto">


    <!-- Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4  xl:grid-cols-4 gap-6 overflow-hidden">

      <% if (categories && categories.length > 0) { %>

        <% categories.forEach((cat,i)=>{ %>

          <div class="category-card bg-white rounded-xl border border-slate-100 shadow hover:shadow-md transition overflow-hidden">

            <!-- Image -->
            <div class="h-40 overflow-hidden">
              <% if(cat.image){ %>

                <a href="/User/category/view/<%= cat.id %>">
                  <img src="/uploads/<%= cat.image %>"
                       class="w-full h-full object-contain bg-slate-50 hover:scale-105 transition duration-300">
                </a>

              <% } else { %>

                <div class="w-full h-full bg-slate-100 flex items-center justify-center">
                  <span class="text-slate-300 text-sm">No Image</span>
                </div>

              <% } %>
            </div>


            <!-- Content -->
            <div class="p-4 space-y-1">

              <div class="flex justify-between">
                <h2 class="font-semibold text-slate-800">
                  <%= cat.category %>
                </h2>

                <span class="text-xs font-semibold text-slate-300">
                  #<%= i+1 %>
                </span>
              </div>

             

            </div>

          </div>

        <% }) %>

      <% } else { %>

        <div class="col-span-4 text-center py-20 text-slate-400 font-semibold">
          No Categories Found
        </div>

      <% } %>

    </div>


    <!-- No Search Result -->
    <div id="noCatResults" class="hidden text-center py-20 text-slate-400 font-semibold">
      No matching categories found
    </div>
  </div>
  </main>
   <!---pagination-->

  <%if(totalPages>1){%>
<div class="flex justify-center items-center gap-2 py-10">


  <!--prev button-->
  <%if(currentPage>1){%>
      <a href="/User/category/categoryList?page=<%=currentPage -1 %>"  class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">Prev</a>

 <% }%>

 <!--page number-->
 <%for(let i=1;i<=totalPages;i++){%>
   <a href="/User/category/categoryList?page=<%=i%>"class="px-4 py-2 rounded-xl text-sm font-bold
         <%= i === currentPage 
            ? 'bg-teal-600 text-white' 
            : 'bg-slate-100 text-slate-600 hover:bg-teal-100' %>"><%=i%></a>

 <%}%>


 <!--next button-->
 <%if(currentPage< totalPages){%>
      <a href="/User/category/categoryList?page=<%=currentPage+1%>" class="px-4 py-2 rounded-xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-teal-100">Next</a>

 <%}%>
</div>
<%}%>


<script>
  const searchCat = document.getElementById("searchCategory");
  const cards = document.querySelectorAll(".category-card");
  const noCatResults = document.getElementById("noCatResults");

  searchCat.addEventListener("input", () => {
    const query = searchCat.value.toLowerCase();
    let visibleCount = 0;

    cards.forEach(card => {
      const text = card.innerText.toLowerCase();
      const match = text.includes(query);
      card.style.display = match ? "block" : "none";
      if (match) visibleCount++;
    });

    noCatResults.style.display = visibleCount === 0 ? "block" : "none";
  });
</script>

</body>
</html>