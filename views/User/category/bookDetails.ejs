<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= book.bookTitle %></title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-100 min-h-screen font-sans">

  <!-- Container -->
  <div class="max-w-7xl mx-auto px-3 sm:px-5 lg:px-8 py-5 sm:py-8 lg:py-10">

    <!-- Book Header -->
    <div class="bg-white rounded-2xl sm:rounded-3xl shadow-lg
                p-4 sm:p-6 lg:p-8
                mb-6 sm:mb-8
                flex flex-col md:flex-row
                gap-5 sm:gap-6 lg:gap-8">

      <!-- Book Image -->
      <div class="flex justify-center md:justify-start flex-shrink-0">

        <img
          src="<%= book.image %>"
          alt="<%= book.bookTitle %>"
          class="w-36 sm:w-44 lg:w-48
                 h-auto
                 rounded-2xl
                 shadow-md
                 object-cover"
        >

      </div>

      <!-- Book Info -->
      <div class="flex-1 text-center md:text-left">

        <h1 class="text-2xl sm:text-3xl lg:text-4xl
                   font-black
                   text-slate-900
                   mb-2">

          <%= book.bookTitle %>

        </h1>

        <p class="text-sm sm:text-base lg:text-lg
                  text-teal-600
                  font-semibold
                  mb-4">

          <%= book.author %>

        </p>

        <p class="text-xs sm:text-sm lg:text-base
                  text-slate-600
                  leading-relaxed">

          <%= book.description %>

        </p>

      </div>

    </div>

    <!-- PDF Reader -->
    <div class="bg-white rounded-2xl sm:rounded-3xl shadow-lg p-4 sm:p-5 lg:p-6">

      <h2 class="text-lg sm:text-xl lg:text-2xl
                 font-bold
                 text-slate-800
                 mb-4">

        📖 Read Book

      </h2>

      <% if (book.pdf) { %>

        <div class="w-full
                    h-[60vh] sm:h-[70vh] lg:h-[75vh]
                    rounded-2xl
                    overflow-hidden
                    border border-slate-200">

          <iframe
            src="https://docs.google.com/gview?embedded=true&url=<%= encodeURIComponent(book.pdf) %>"
            class="w-full h-full"
            style="border:none"
          ></iframe>

        </div>

        <!-- PDF Link -->
        <div class="mt-4 break-all">

          <p class="text-[11px] sm:text-xs lg:text-sm text-slate-400">
            <%= book.pdf %>
          </p>

        </div>

      <% } else { %>

        <p class="text-sm sm:text-base text-slate-400 italic">
          PDF not available
        </p>

      <% } %>

    </div>

  </div>

</body>
</html>