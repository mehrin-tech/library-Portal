<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Portal | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root { --primary-teal: #008080; }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
    .border-teal-primary { border-color: var(--primary-teal); }
    .focus-ring-teal:focus { --tw-ring-color: var(--primary-teal); border-color: var(--primary-teal); }
    .modal-animate-in { animation: fadeIn 0.2s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
  </style>
</head>
<body class="bg-slate-50 min-h-screen font-sans">

<%- include('../partials/userSidebar') %>

<main class="ml-20 p-8 transition-all duration-300">

  <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-6">
    <div class="space-y-1">
      <h1 class="text-2xl font-black text-slate-800 tracking-tight leading-tight">
        Hello, <span class="text-[#2d8a75]"><%= username %></span> 
      </h1>
      <div class="flex items-center gap-3 text-xs font-bold text-slate-400 uppercase tracking-widest">
        <span><%= date %></span>
        <span class="w-1 h-1 bg-slate-300 rounded-full"></span>
        <span><%= time %></span>
      </div>
    </div>

    <button 
      onclick="openProfileModal()" 
      class="group flex items-center gap-3 bg-white p-2 pr-6 rounded-2xl shadow-sm border border-slate-200 hover:shadow-md transition-all active:scale-95"
    >
      <% if (image) { %>
        <img src="/uploads/<%= image %>" class="w-10 h-10 rounded-xl object-cover ring-2 ring-teal-500/10" />
      <% } else { %>
        <div class="w-10 h-10 rounded-xl bg-teal-600 flex items-center justify-center text-white font-black uppercase">
          <%= username.charAt(0) %>
        </div>
      <% } %>
      <div class="text-left">
        <p class="text-[10px] font-black text-slate-400 uppercase leading-none">Profile of</p> 
        <p class="text-sm font-bold text-slate-700"><%=username%></p>
      </div>
    </button>
  </header> 
  

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
    <div class="bg-white p-8 rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 relative overflow-hidden">
      <div class="absolute -right-4 -top-4 w-24 h-24 bg-slate-50 rounded-full"></div>
      <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest relative z-10">📚 Books List</p>
      <h3 class="text-4xl font-black text-slate-800 mt-2 relative z-10"><%= totalBooks %></h3>
    </div>

    <a href="/User/issued/<%= userId %>" class="group bg-white p-8 rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 relative overflow-hidden transition-all hover:-translate-y-1">
       <!-- background circle -->
  <div class="absolute -right-4 -top-4 w-24 h-24 bg-teal-50 rounded-full transition-transform group-hover:scale-110"></div>

  <!-- title -->
      <!-- title -->
  <p class="text-[10px] font-black text-teal-600 uppercase tracking-widest relative z-10">
    📖 Issued Books
  </p>
      <!-- count -->
  <h3 class="text-4xl font-black text-slate-800 mt-2 relative z-10">
    <%= issuedCount %>
  </h3>
      <!--fine notification-->
<%if (totalFine > 0){%>
<div class="mt-4 bg-red-50 border border-red-200 p-4 rounded-xl">
    <p class="text-red-700 font-bold">
      🔔 Pending Fine: ₹<%= totalFine %>
    </p>


    <a href="/User/pay-fine" class="inline-block mt-2 bg-[#008080] text-white px-4 py-2 rounded-lg text-sm font-bold ">OK</a>
    </div>

<%}%>
    </a>

    <a href="/user/usedBooks" class="group bg-[#2d8a75] p-8 rounded-[2rem] shadow-xl shadow-teal-900/20 relative overflow-hidden transition-all hover:-translate-y-1">
      <div class="absolute -right-4 -top-4 w-24 h-24 bg-teal-700/50 rounded-full"></div>
      <p class="text-[10px] font-black text-teal-100 uppercase tracking-widest relative z-10">📘 Total Usage</p>
      <h3 class="text-4xl font-black text-white mt-2 relative z-10"><%= totalUsedBooks %></h3>
    </a>
      <a href="/User/category/categoryList" class="group bg-white p-8 rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100 relative overflow-hidden transition-all hover:-translate-y-1">
      <div class="absolute -right-4 -top-4 w-24 h-24 bg-teal-50 rounded-full transition-transform group-hover:scale-110"></div>
      <p class="text-[10px] font-black text-teal-600 uppercase tracking-widest relative z-10">📖Library Collections </p>
      <h5 class="text-xl font-black text-slate-800 mt-2 relative z-10">E-Book Reader</h5>
    </a>
  </div>

  <div class="bg-white rounded-[2.5rem] shadow-2xl shadow-slate-200/60 border border-slate-100 overflow-hidden">
    <div class="p-8 border-b border-slate-50 flex flex-col md:flex-row justify-between items-center gap-6">
      <h2 class="text-xl font-black text-slate-800 tracking-tight">Book List</h2>
      <div class="relative w-full md:w-72">
        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </span>
        <input 
          type="text" id="searchInp" placeholder="Quick Search..." 
          class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-2xl text-xs font-bold focus:outline-none focus:ring-2 focus-ring-teal transition-all shadow-sm"
        >
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-left border-separate border-spacing-0">
        <thead>
          <tr class="bg-slate-50/50">
            <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Book Title</th>
            <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Author</th>
            <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">ISBN</th>
            <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Status</th>
            <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Arrival</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-50">
          <% books.forEach((b, index)=> { %>
            <tr class="book-row group transition-colors <%= Number(b.quantity) === 0 ? 'bg-slate-50/50 cursor-not-allowed' : 'hover:bg-teal-50/30' %>">
              <td class="px-8 py-5 book-name">
                <% if(Number(b.quantity) === 0) { %>
                  <span class="text-sm font-bold text-slate-400"><%= b.title %></span>
                <% } else { %>
                  <a href="/User/viewBooks/<%= b.id %>" class="text-sm font-bold text-slate-800 hover:text-teal-600 transition-all">
                    <%= b.title %>
                  </a>
                <% } %>
              </td>
              <td class="px-8 py-5 text-sm font-medium text-slate-500"><%= b.author %></td>
              <td class="px-8 py-5 font-mono text-xs text-slate-400"><%= b.isbn %></td>
              
              <td class="px-8 py-5 text-center whitespace-nowrap">
                <% if (b.availableCopies === 0) { %>
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-rose-50 text-rose-600 border border-rose-100">
                    <span class="w-1.5 h-1.5 mr-1.5 rounded-full bg-rose-500 animate-pulse"></span>
                    Out of Stock
                  </span>
                <% } else if (b.availableCopies < 10) { %>
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-amber-50 text-amber-700 border border-amber-200">
                    <svg class="w-3 h-3 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"/></svg>
                    Low: <%= b.availableCopies %> Left
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-teal-50 text-teal-primary border border-teal-100">
                    <span class="w-1.5 h-1.5 mr-1.5 rounded-full bg-teal-500"></span>
                    <%= b.availableCopies %> Available
                  </span>
                <% } %>
              </td>

              <td class="px-8 py-5 text-xs text-slate-400 font-medium"><%= new Date(b.createdAt).toLocaleDateString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
    <div class="flex items-center justify-between px-8 py-6  border-t border-slate-50">
  <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
    Page <%= currentPage %> of <%= totalPages %>
  </div>

  <div class="flex items-center gap-2">
    <% if (currentPage > 1) { %>
      <a href="?page=<%= currentPage - 1 %>" 
         class="flex items-center justify-center px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-500 bg-slate-50 border border-slate-200 rounded-xl hover:bg-teal-50 hover:text-teal-600 hover:border-teal-200 transition-all active:scale-95">
        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        Prev
      </a>
    <% } else { %>
      <span class="flex items-center justify-center px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-300 bg-slate-50/50 border border-slate-100 rounded-xl cursor-not-allowed">
        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        Prev
      </span>
    <% } %>

    <div class="flex items-center gap-1 mx-2">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="?page=<%= i %>"
           class="w-9 h-9 flex items-center justify-center rounded-xl text-xs font-black transition-all active:scale-90
           <%= currentPage === i 
               ? 'bg-teal-primary text-white shadow-lg shadow-teal-900/20' 
               : 'text-slate-500 hover:bg-slate-100 border border-transparent hover:border-slate-200' %>">
            <%= i %>
        </a>
      <% } %>
    </div>

    <% if (currentPage < totalPages) { %>
      <a href="?page=<%= currentPage + 1 %>" 
         class="flex items-center justify-center px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-500 bg-slate-50 border border-slate-200 rounded-xl hover:bg-teal-50 hover:text-teal-600 hover:border-teal-200 transition-all active:scale-95">
        Next
        <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </a>
    <% } else { %>
      <span class="flex items-center justify-center px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-300 bg-slate-50/50 border border-slate-100 rounded-xl cursor-not-allowed">
        Next
        <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </span>
    <% } %>
  </div>
</div>

  <a href="/User/stdChat" class="fixed bottom-8 right-8 w-16 h-16 bg-[#2d8a75] text-white rounded-2xl flex items-center justify-center shadow-2xl shadow-teal-900/40 hover:-translate-y-2 active:scale-95 transition-all z-40 group">
     <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
    </svg> 
    <span class="absolute right-20 bg-slate-800 text-white text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Chat with Admin</span>
  </a>
</main>
<div id="profileModal" class="fixed inset-0 z-[60] hidden flex items-center justify-center p-6 ">

  <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeProfile()"></div>

  <div class="bg-white rounded-[2.5rem] w-full max-w-lg shadow-2xl shadow-slate-200/60 relative z-10 overflow-hidden border border-slate-100">

    <div class="p-8">

      <!-- Header -->
      <div class="flex flex-col md:flex-row items-center gap-6 mb-8 pb-8 border-b border-slate-50">

        <div class="relative">
          <% if (image) { %>
            <img
              src="/uploads/<%= image %>"
              class="w-28 h-28 rounded-[2rem] object-cover ring-4 ring-teal-50 shadow-lg"
            />
          <% } else { %>
            <div class="w-28 h-28 rounded-[2rem] bg-teal-600 flex items-center justify-center text-white text-3xl font-black shadow-lg">
              <%= username.charAt(0) %>
            </div>
          <% } %>

        </div>

        <div class="text-center md:text-left">
          <h2 class="text-2xl font-black text-slate-800">
            <%= username %>
          </h2>

       
        </div>

      </div>


      <!-- Details -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

        <div>
          <p class="text-sm font-black text-slate-400">Email</p>
          <p class="text-base font-semibold text-slate-700">
            <%= email %>
          </p>
        </div>

        <div>
          <p class="text-sm font-black text-slate-400">Department</p>
          <p class="text-base font-semibold text-slate-700">
            <%= department %>
          </p>
        </div>

        <div>
          <p class="text-sm font-black text-slate-400">Semester</p>
          <p class="text-base font-semibold text-slate-700">
            Semester <%= semester %>
          </p>
        </div>

        <div>
          <p class="text-sm font-black text-slate-400">Status</p>

          <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full font-semibold
            <%= status === 'Active'
              ? 'bg-green-50 text-green-600 border border-green-100'
              : 'bg-red-50 text-red-600 border border-red-100' %>">

            <span class="w-1.5 h-1.5 rounded-full
              <%= status === 'Active' ? 'bg-green-500' : 'bg-red-500' %>">
            </span>

            <%= status %>
          </span>

        </div>

      </div>


      <!-- Buttons -->
      <div class="flex flex-col md:flex-row gap-3">

        <button onclick="closeProfile()"
          class="flex-1 px-6 py-3 rounded-xl border border-slate-200 text-slate-500 text-sm font-semibold hover:bg-slate-50 transition">
          Cancel
        </button>

        <a href="/User/edit/<%= userId %>"
          class="flex-1 px-6 py-3 rounded-xl bg-[#2d8a75] text-white text-sm font-semibold shadow-md hover:bg-teal-700 transition text-center">
          Edit Profile
        </a>

      </div>

    </div>

  </div>

</div>

  </div>
</div>

<script>
  function openProfileModal(){ document.getElementById('profileModal').classList.remove('hidden') }
  function closeProfile(){ document.getElementById('profileModal').classList.add('hidden') }

  const bookSearch = document.getElementById('searchInp')
  const rows = document.querySelectorAll('.book-row')

  bookSearch.addEventListener('input', function () {
    const val = bookSearch.value.toLowerCase().trim()
    rows.forEach(row => {
      const bookName = row.querySelector('.book-name').textContent.toLowerCase()
      row.style.display = bookName.includes(val) ? '' : 'none'
    })
  })
</script>



</body>
</html>