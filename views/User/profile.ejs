<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Profile | Library System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  
</head>

<body class="bg-slate-50 min-h-screen font-sans">

  <%- include('../partials/userSidebar') %>

 <main class="ml-20 flex items-center justify-center min-h-screen p-4">

  <div class="w-full max-w-lg bg-white rounded-2xl shadow-lg border border-slate-100 overflow-hidden">

    <div class="p-6 md:p-8">

      <div class="flex flex-col md:flex-row items-center gap-5 mb-8 pb-6 border-b border-slate-50">

        <div class="relative">
          <img
            src="/uploads/<%= student.image %>"
            alt="Student Photo"
            class="w-24 h-24 rounded-2xl object-cover ring-2 ring-teal-50 shadow-md"
          />
        </div>

        <div class="text-center md:text-left">
          <h2 class="text-2xl font-bold text-slate-800">
            <%= student.username %>
          </h2>
        </div>

      </div>


      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">

        <div>
          <p class="text-sm font-semibold text-slate-400">Department</p>
          <p class="text-base font-semibold text-slate-700">
            <%= student.department %>
          </p>
        </div>

        <div>
          <p class="text-sm font-semibold text-slate-400">Semester</p>
          <p class="text-base font-semibold text-slate-700">
            Semester <%= student.semester %>
          </p>
        </div>

        <div>
          <p class="text-sm font-semibold text-slate-400">Email</p>
          <p class="text-base font-semibold text-slate-700">
            <%= student.email %>
          </p>
        </div>

        <div>
          <p class="text-sm font-semibold text-slate-400">Status</p>

          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-semibold
            <%= student.status === 'Active'
              ? 'bg-green-50 text-green-600 border border-green-100'
              : 'bg-red-50 text-red-600 border border-red-100' %>">

            <span class="w-1.5 h-1.5 rounded-full
              <%= student.status === 'Active' ? 'bg-green-500' : 'bg-red-500' %>">
            </span>

            <%= student.status %>
          </span>

        </div>

      </div>


      <div class="flex flex-col md:flex-row gap-3">

        <a href="/User/dashboard/<%=student.id%>"
          class="flex-1 px-6 py-3 rounded-xl border border-slate-200 text-slate-500 text-sm font-semibold hover:bg-slate-50 transition text-center">
          Return to Dashboard
        </a>

        <a href="/User/edit/<%=student.id%>"
          class="flex-1 px-6 py-3 rounded-xl bg-[#2d8a75] text-white text-sm font-semibold shadow-md hover:bg-teal-700 transition text-center">
          Update Profile
        </a>

      </div>

    </div>

  </div>

</main>


</body>
</html>