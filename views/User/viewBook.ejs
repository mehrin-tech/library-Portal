<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= b.bookname %> | Catalog Details</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root { --primary-teal: #008080; }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
  </style>
</head>

<body class="bg-slate-50 min-h-screen font-sans">

  <%- include('../partials/userSidebar') %>

<main class="ml-0 md:ml-20
flex items-center justify-center
min-h-screen
p-3 sm:p-5 lg:p-8">    
    <div class="w-full max-w-5xl bg-white rounded-2xl sm:rounded-[2.5rem] shadow-2xl shadow-slate-200/60 border border-slate-100 overflow-hidden flex flex-col md:flex-row">
      
      <div class="md:w-2/5 bg-slate-900 p-6 sm:p-8 lg:p-12 flex flex-col items-center justify-center relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-teal-500/10 rounded-full blur-3xl -mr-16 -mt-16"></div>
        
        <div class="relative group">
            <img src="<%= b.image %>" alt="<%= b.bookname %>" 
                 class="w-44 h-64
sm:w-56 sm:h-80
lg:w-64 lg:h-96 object-cover rounded-2xl shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]">
            <div class="absolute top-4 -right-2">
                <% if (b.quantity > 0) { %>
                    <span class="bg-emerald-500 text-white text-[9px] sm:text-[10px] font-black uppercase tracking-widest px-3 sm:px-4 py-1 sm:py-1.5 rounded-l-lg shadow-lg">Available</span>
                <% } else { %>
                    <span class="bg-rose-500 text-white text-[9px] sm:text-[10px] font-black uppercase tracking-widest px-3 sm:px-4 py-1 sm:py-1.5 rounded-l-lg shadow-lg">Out of Stock</span>
                <% } %>
            </div>
        </div>
      </div>

      <div class="md:w-3/5 p-5 sm:p-8 md:p-12 lg:p-16 flex flex-col">
        
        <div class="mb-10">
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black text-slate-800 tracking-tight leading-tight mb-2"><%= b.bookname %></h1>
            <p class="text-xs sm:text-sm sm:text-base lg:text-lg font-bold text-slate-400 italic">by <%= b.author %></p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5 lg:gap-6 mb-12">
          
          <div class="p-3 sm:p-4 bg-slate-50 rounded-2xl border border-slate-100">
            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">ISBN </p>
            <p class="text-xs sm:text-sm font-bold text-slate-700 tracking-tight"><%= b.isbn %></p>
          </div>

          <div class="p-3 sm:p-4 bg-slate-50 rounded-2xl border border-slate-100">
            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">ID</p>
            <p class="text-xs sm:text-sm font-bold text-slate-700 tracking-tight">#<%= b.id %></p>
          </div>

          <div class="p-3 sm:p-4 bg-slate-50 rounded-2xl border border-slate-100">
            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Copies</p>
            <p class="text-xs sm:text-sm font-bold text-slate-700 tracking-tight"><%= b.availableCopies %> </p>
          </div>

          <div class="p-3 sm:p-4 bg-slate-50 rounded-2xl border border-slate-100">
            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Arrival Date</p>
            <p class="text-xs sm:text-sm font-bold text-slate-700 tracking-tight"><%=  new Date(b.createdAt).toLocaleDateString() %></p>
          </div>

        </div>

        <div class="mt-auto flex items-center gap-4">
          <a href="/User/dashboard/<%=userId%>" 
             class="px-5 sm:px-6 lg:px-8
py-3 sm:py-4 rounded-2xl border border-slate-200 text-slate-400 text-[9px] sm:text-[10px] font-black uppercase tracking-widest hover:bg-slate-50 transition-all text-center flex-1">
            Return to  dashboard
          </a>
          
         
        </div>

      </div>

    </div>
  </main>

</body>
</html>