<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Issued Books Ledger | Student Portal</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root { --primary-teal: #008080; }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .text-teal-primary { color: var(--primary-teal); }
    .border-teal-primary { border-color: var(--primary-teal); }
  </style>
</head>

<body class="bg-slate-50 min-h-screen font-sans">

  <%- include('../partials/userSidebar') %>

  <main class="ml-20 p-8 transition-all duration-300">

    <header class="flex justify-between items-center mb-10">
      <div class="space-y-1">
        <h1 class="text-3xl font-black text-slate-800 tracking-tight">Issued <span class="text-[#2d8a75]">Books List</span></h1>
       
      </div>
      
      <a href="/User/dashboard/<%=userId%>" 
         class="flex items-center gap-2 px-5 py-2.5 bg-white border border-slate-200 rounded-xl text-xs font-bold text-slate-600 hover:bg-slate-50 transition-all shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Dashboard
      </a>
    </header>

    <div class="bg-white rounded-[2.5rem] shadow-2xl shadow-slate-200/60 border border-slate-100 overflow-hidden">
      
      <div class="overflow-x-auto">
        <table class="w-full text-left border-separate border-spacing-0">
          
          <thead>
            <tr class="bg-slate-50/50">
                            <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">ID</th>

              <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Book Name</th>
              <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Issue Date</th>
              <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Return Date</th>
              <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Status</th>
              <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Manage</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-50">

            <% if (issued.length === 0) { %>
              <tr>
                <td colspan="5" class="px-8 py-20 text-center">
                  <div class="flex flex-col items-center">
                    <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-300 mb-4">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.168.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                      </svg>
                    </div>
                    <p class="text-sm font-bold text-slate-400 uppercase tracking-widest">No Active Records Found</p>
                  </div>
                </td>
              </tr>
            <% } %>

            <% issued.forEach((i ,d)=> { %>
              <tr class="group hover:bg-teal-50/30 transition-all">
                <td class="px-8 py-6">
<span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mt-1">Ref ID: #<%= d+1 %></span>                </td>
                <td class="px-8 py-6">
                  <div class="flex flex-col">
                    <span class="text-sm font-black text-slate-800 group-hover:text-teal-700 transition-colors">
                      <%= i.book?.bookname || i.book?.title || 'Unknown Book' %>
                    </span>
                    
                  </div>
                </td>

                <td class="px-8 py-6">
                  <span class="text-xs font-bold text-slate-600 tracking-tight"><%=new Date(i.createdAt) .toLocaleDateString()%></span>
                </td>

                <td class="px-8 py-6">
                  <span class="text-xs font-bold text-slate-600 tracking-tight"> <%= i.returnDate ? new Date(i.returnDate).toLocaleDateString() : '-' %></span>
                </td>

                <td class="px-8 py-6">
                  <% if (i.status === 'issued') { %>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-teal-50 text-teal-600 border border-teal-100">
                      <span class="w-1.5 h-1.5 bg-teal-500 rounded-full animate-pulse"></span>
                     Issued
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-slate-100 text-slate-500 border border-slate-200">
                      Returned
                    </span>
                  <% } %>
                </td>

                <td class="px-8 py-6 text-center">
                  <% if (i.status === 'issued' && !i.returnRequested) { %>
                    <form action="/user/request-return/<%= i.id %>" method="post">
                      <button class="bg-[#2d8a75] text-white text-[10px] font-black uppercase tracking-widest px-5 py-2.5 rounded-xl shadow-lg shadow-teal-900/10 hover:bg-teal-700 hover:-translate-y-0.5 active:scale-95 transition-all">
                        Request Return
                      </button>
                    </form>
               
                  <% } else { %>
                    <span class="text-slate-300 font-bold">—</span>
                  <% } %>
                </td>

              </tr>
            <% }) %>

          </tbody>
        </table>
      </div>
    </div>
     <div class="flex items-center justify-between px-8 py-6  border-t border-slate-50">
  <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
    Page <%= currentPage %> of <%= totalPages %>
  </div>

  <div class="flex items-center gap-2">
    <% if (currentPage > 1) { %>
      <a href="?page=<%= currentPage - 1 %>" 
         class="flex items-center justify-center px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-500 bg-[#2d8a75] border border-slate-200 rounded-xl  hover:text-teal-600 hover:border-teal-200 transition-all active:scale-95">
        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        Prev
      </a>
    <% } else { %>
      <span class="flex items-center justify-center px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-300 bg-slate-50/50 border border-slate-100 rounded-xl cursor-not-allowed">
        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        Prev
      </span>
    <% } %>

    <div class="flex items-center gap-1 mx-2">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="?page=<%= i %>"
           class="w-9 h-9 flex items-center justify-center rounded-xl text-xs font-black transition-all active:scale-90
           <%= currentPage === i 
               ? 'bg-teal-primary text-white shadow-lg shadow-teal-900/20' 
               : 'text-slate-500 hover:bg-slate-100 border border-transparent hover:border-slate-200' %>">
            <%= i %>
        </a>
      <% } %>
    </div>

    <% if (currentPage < totalPages) { %>
      <a href="?page=<%= currentPage + 1 %>" 
         class="flex items-center justify-center px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-500 bg-slate-50 border border-slate-200 rounded-xl hover:bg-teal-50 hover:text-teal-600 hover:border-teal-200 transition-all active:scale-95">
        Next
        <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </a>
    <% } else { %>
      <span class="flex items-center justify-center px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-300 bg-slate-50/50 border border-slate-100 rounded-xl cursor-not-allowed">
        Next
        <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </span>
    <% } %>
  </div>
</div>
  </main>
 

</body>
</html>
