<body class="min-h-screen flex items-center justify-center py-4 px-3 bg-slate-50">

  <div class="relative bg-white w-full max-w-xl rounded-xl shadow border border-slate-100 overflow-hidden">

    <div class="max-h-[90vh] overflow-y-auto p-4 md:p-5">

      <div class="mb-4">
        <h1 class="text-xl font-bold text-slate-900 text-center">Edit Profile</h1>
      </div>

      <form action="/User/update/<%= user.id %>" method="POST" class="space-y-4" enctype="multipart/form-data">

        <!-- Profile Image -->
        <div class="flex flex-col md:flex-row items-center gap-3 pb-4 border-b border-slate-50">

          <div class="w-20 h-20 rounded-lg bg-slate-100 flex items-center justify-center border border-slate-200 overflow-hidden">

            <% if (user.image) { %>
              <img src="/uploads/<%= user.image %>" class="w-full h-full object-cover">
            <% } else { %>
              <span class="text-2xl font-bold">
                <%= user.username ? user.username.charAt(0) : 'U' %>
              </span>
            <% } %>

          </div>

          <div class="flex-1 space-y-1 text-center md:text-left">
           
            <input type="file" name="image" accept="image/*"
              class="text-xs file:mr-2 file:py-1.5 file:px-3 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-teal-50 file:text-teal-700 cursor-pointer" />
          </div>

        </div>


        <!-- Form Fields -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">

          <div class="space-y-1">
            <label class="text-[11px] font-semibold text-slate-500">Username</label>
            <input type="text" name="username" value="<%= user.username %>"
              class="w-full rounded-md border border-slate-200 px-3 py-1.5 text-sm focus:border-teal-600 focus:ring-1 focus:ring-teal-100 outline-none" required />
          </div>

          <div class="space-y-1">
            <label class="text-[11px] font-semibold text-slate-500">Email</label>
            <input type="email" name="email" value="<%= user.email %>"
              class="w-full rounded-md border border-slate-200 px-3 py-1.5 text-sm focus:border-teal-600 focus:ring-1 focus:ring-teal-100 outline-none" required />
          </div>

          <div class="space-y-1">
            <label class="text-[11px] font-semibold text-slate-500">Department</label>
            <input type="text" name="department" value="<%= user.department %>"
              class="w-full rounded-md border border-slate-200 px-3 py-1.5 text-sm focus:border-teal-600 focus:ring-1 focus:ring-teal-100 outline-none" />
          </div>

          <div class="space-y-1">
            <label class="text-[11px] font-semibold text-slate-500">Semester</label>
            <input type="text" name="semester" value="<%= user.semester %>"
              class="w-full rounded-md border border-slate-200 px-3 py-1.5 text-sm focus:border-teal-600 focus:ring-1 focus:ring-teal-100 outline-none" />
          </div>

        </div>


        <!-- Status -->
        <div class="space-y-1">
          <label class="text-[11px] font-semibold text-slate-500">Profile Status</label>

          <select name="status"
            class="w-full rounded-md border border-slate-200 px-3 py-1.5 text-sm focus:border-teal-600 focus:ring-1 focus:ring-teal-100 outline-none">

            <option value="Active" <%= user.status === 'Active' ? 'selected' : '' %>>Active</option>
            <option value="Inactive" <%= user.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>

          </select>
        </div>


        <!-- Buttons -->
        <div class="flex flex-col md:flex-row gap-2 pt-2">

          <a href="/User/dashboard/<%= user.id %>"
            class="flex-1 px-5 py-2 rounded-md border border-slate-200 text-slate-500 text-xs font-semibold hover:bg-slate-50 text-center">
            Cancel
          </a>

          <button type="submit"
            class="flex-1 px-5 py-2 rounded-md bg-teal-600 text-white text-xs font-semibold hover:bg-teal-700 transition">
            Save
          </button>

        </div>

      </form>

    </div>
  </div>

</body>

</html>