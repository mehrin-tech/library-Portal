
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Profile | Student Portal</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primary-teal: #2d8a75; }
    body { 
        font-family: 'Plus Jakarta Sans', sans-serif; 
        background-color: #f8fafc; /* Professional slate-50 */
    }
    
    .input-field { 
      width: 100%; border-radius: 10px; border: 1px solid #e2e8f0; padding: 12px 16px; 
      font-size: 0.875rem; transition: all 0.2s; background-color: white;
    }
    
    .input-field:focus { 
        border-color: var(--primary-teal); 
        box-shadow: 0 0 0 4px rgba(45, 138, 117, 0.1); 
        outline: none; 
    }

    /* Professional Background Pattern */
    .bg-pattern {
        background-image: radial-gradient(#2d8a75 0.5px, transparent 0.5px);
        background-size: 24px 24px;
        opacity: 0.05;
    }
  </style>
</head>

<body class="min-h-screen flex items-center justify-center py-12 px-4 relative">
  <div class="absolute inset-0 bg-pattern pointer-events-none"></div>

  <div class="relative bg-white w-full max-w-2xl rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.05)] border border-slate-100 overflow-hidden">
    
    <div class="p-8 md:p-12">
      <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Edit Profile</h1>
        </div>
       
      </div>

      <form action="/User/update/<%= user.id %>" method="POST" class="space-y-8" enctype="multipart/form-data">
        
        <div class="flex flex-col md:flex-row items-center gap-8 pb-8 border-b border-slate-50">
            <div class="relative group">
                <div class="w-28 h-28 rounded-2xl bg-slate-100 flex items-center justify-center text-slate-400 border border-slate-200 overflow-hidden shadow-inner">
                    <% if (user.image) { %>
                        <img src="/uploads/<%= user.image %>" class="w-full h-full object-cover">
                    <% } else { %>
                        <span class="text-4xl font-bold"><%= user.username ? user.username.charAt(0) : 'U' %></span>
                    <% } %>
                    <div class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center cursor-pointer">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              
                          </svg>
                    </div>
                </div>
                
            </div>
            
            <div class="flex-1 space-y-2 text-center md:text-left">
                <label class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">New Profile Photo</label>
                <input type="file" name="image" accept="image/*" class="text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-teal-50 file:text-teal-700 hover:file:bg-teal-100 transition-all cursor-pointer" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="text-[11px] font-bold text-slate-500 uppercase tracking-wider ml-1">Username</label>
            <input type="text" name="username" value="<%= user.username %>" class="input-field" required />
          </div>

          <div class="space-y-2">
            <label class="text-[11px] font-bold text-slate-500 uppercase tracking-wider ml-1">Email Address</label>
            <input type="email" name="email" value="<%= user.email %>" class="input-field" required />
          </div>

          <div class="space-y-2">
            <label class="text-[11px] font-bold text-slate-500 uppercase tracking-wider ml-1">Department</label>
            <input type="text" name="department" value="<%= user.department %>" class="input-field" />
          </div>

          <div class="space-y-2">
            <label class="text-[11px] font-bold text-slate-500 uppercase tracking-wider ml-1">Current Semester</label>
            <input type="text" name="semester" value="<%= user.semester %>" class="input-field" />
          </div>
        </div>
        
        <div class="space-y-2">
          <label class="text-[11px] font-bold text-slate-500 uppercase tracking-wider ml-1">Profile Status</label>
          <div class="relative">
              <select name="status" class="input-field appearance-none cursor-pointer pr-10 font-semibold">
                <option value="Active" <%= user.status === 'Active' ? 'selected' : '' %>>Active Status</option>
                <option value="Inactive" <%= user.status === 'Inactive' ? 'selected' : '' %>>Inactive Status</option>
              </select>
              <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-slate-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
              </div>
          </div>
        </div>

        <div class="flex flex-col md:flex-row justify-end gap-3 pt-8 mt-4">
          <a href="/User/dashboard/<%= user.id %>" 
             class="px-8 py-3.5 rounded-xl border border-slate-200 text-slate-600 text-[11px] font-bold uppercase tracking-widest hover:bg-slate-50 transition-all text-center">
            Discard Changes
          </a>
          <button type="submit" 
                  class="px-10 py-3.5 rounded-xl bg-[#2d8a75] text-white text-[11px] font-bold uppercase tracking-widest shadow-[0_10px_20px_rgba(45,138,117,0.2)] hover:bg-[#246e5d] hover:shadow-none hover:translate-y-0.5 transition-all">
            Save Settings
          </button>
        </div>

      </form>
    </div>
  </div>

</body>
</html>