<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Profile | Student Portal</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root { --primary-teal: #008080; }
    .bg-teal-primary { background-color: var(--primary-teal); }
    .focus-ring-teal:focus { outline: none; ring: 2px; ring-color: var(--primary-teal); border-color: var(--primary-teal); }
    .input-field { 
      width: 100%; border-radius: 12px; border: 1px solid #e2e8f0; padding: 10px 16px; 
      font-size: 0.875rem; transition: all 0.2s; background-color: #f8fafc;
    }
    .input-field:focus { background-color: white; border-color: var(--primary-teal); box-shadow: 0 0 0 3px rgba(0, 128, 128, 0.1); outline: none; }
  </style>
</head>

<body class="bg-slate-50 min-h-screen flex items-center justify-center py-12 px-4">

  <div class="bg-white w-full max-w-2xl rounded-[2.5rem] shadow-2xl shadow-slate-200/60 border border-slate-100 overflow-hidden">
    
    <div class="h-2 bg-teal-primary w-full"></div>

    <div class="p-8 md:p-12">
      <div class="mb-10 text-center md:text-left">
        <h1 class="text-3xl font-black text-slate-800 tracking-tight">Edit <span class="text-teal-600">Profile</span></h1>
      </div>

      <form action="/User/update/<%= user.id %>" method="POST" class="space-y-8" enctype="multipart/form-data">
        
        <div class="flex flex-col md:flex-row items-center gap-6 pb-8 border-b border-slate-100">
            <div class="w-24 h-24 rounded-3xl bg-teal-50 flex items-center justify-center text-teal-600 border-2 border-dashed border-teal-200 relative group overflow-hidden">
                <% if (user.image) { %>
                    <img src="/uploads/<%= user.image %>" class="w-full h-full object-cover">
                <% } else { %>
                    <span class="text-3xl font-black"><%= user.username?user.username.charAt(0) :'U' %></span>
                <% } %>
                <div class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                </div>
            </div>
            <div class="text-center md:text-left">
                <p class="text-sm font-bold text-slate-700">Profile Photo</p>
                </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Username</label>
            <input type="text" name="username" value="<%= user.username %>" class="input-field" required />
          </div>

          <div class="space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Email</label>
            <input type="email" name="email" value="<%= user.email %>" class="input-field" required />
          </div>

          <div class="space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Department</label>
            <input type="text" name="department" value="<%= user.department %>" class="input-field" />
          </div>

          <div class="space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Semester</label>
            <input type="text" name="semester" value="<%= user.semester %>" class="input-field" />
          </div>
        </div>
        
        <div class="space-y-2">
          <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Status</label>
          <div class="relative">
              <select name="status" class="input-field appearance-none cursor-pointer">
                <option value="Active" <%= user.status === 'Active' ? 'selected' : '' %>>🟢 Active </option>
                <option value="Inactive" <%= user.status === 'Inactive' ? 'selected' : '' %>>🔴 Inactive </option>
              </select>
              <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-slate-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
              </div>
          
           <div class="space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Image</label>
            <input type="file" name="image" accept="image/*"  class="input-field" />
          </div>
        </div>
     

        <div class="flex flex-col md:flex-row justify-end gap-4 pt-8 border-t border-slate-100">
          <a href="/User/dashboard/<%= user.id %>" 
             class="px-8 py-4 rounded-2xl border border-slate-200 text-slate-400 text-[10px] font-black uppercase tracking-widest hover:bg-slate-50 transition-all text-center">
            Cancel 
          </a>
          <button type="submit" 
                  class="px-10 py-4 rounded-2xl bg-teal-primary text-white text-[10px] font-black uppercase tracking-widest shadow-xl shadow-teal-900/20 hover:bg-teal-700 hover:-translate-y-1 active:scale-95 transition-all">
            Update Profile
          </button>
        </div>

      </form>
    </div>
  </div>

</body>
</html>