<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Library Sidebar</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Defining your primary teal exactly */
        :root { --primary-teal: #008080; }
        .bg-teal-primary { background-color: var(--primary-teal); }
        .active-link{
          background-color:rgba(0, 77, 77, 0.85);
           color: white !important;
            box-shadow: 0 0 12px rgba(0, 77, 77, 0.7);
        }
    </style>
</head>
<body>
  <aside
    class="fixed left-0 top-0 z-50
           h-screen w-20
           bg-[#008080] 
           flex flex-col items-center
           py-8 gap-6
            shadow-[10px_0_30px_rgba(0,128,128,0.2)] border-r border-white/10">

    <div class="w-12 h-12 bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center shadow-lg mb-4">
      <a href="/"><svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.168.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      </a>
    </div>

    <div class="w-8 h-[1px] bg-white/20 mb-2"></div>

   
             <a href="/User/dashboard/<%=userId%>"
   class="nav-link group relative flex items-center justify-center
          w-12 h-12 rounded-2xl
          text-teal-100/50
          hover:text-white hover:bg-teal-500/20 transition-all duration-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      <span class="absolute left-16 scale-0 group-hover:scale-100 transition-all origin-left bg-white text-[#008080] text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest pointer-events-none shadow-xl z-50">Dashboard</span>
    </a>

   
                    <a href="/User/usedBooks"
   class="nav-link group relative flex items-center justify-center
          w-12 h-12 rounded-2xl
          text-teal-100/50
          hover:text-white hover:bg-teal-500/20 transition-all duration-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.168.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      <span class="absolute left-16 scale-0 group-hover:scale-100 transition-all origin-left bg-white text-[#008080] text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest pointer-events-none shadow-xl z-50">History</span>
    </a>

  
                    <a href="/User/issued/<%=userId%>"
   class="nav-link group relative flex items-center justify-center
          w-12 h-12 rounded-2xl
          text-teal-100/50
          hover:text-white hover:bg-teal-500/20 transition-all duration-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
      </svg>
      <span class="absolute left-16 scale-0 group-hover:scale-100 transition-all origin-left bg-white text-[#008080] text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest pointer-events-none shadow-xl z-50">Issued</span>
    </a>
    
           <a href="/User/stdChat"
   class="nav-link group relative flex items-center justify-center
          w-12 h-12 rounded-2xl
          text-teal-100/50
          hover:text-white hover:bg-teal-500/20 transition-all duration-300">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
    </svg>
    <span class="absolute left-16 scale-0 group-hover:scale-100 transition-all origin-left bg-slate-800 text-white text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest pointer-events-none shadow-xl z-50">Support</span>
  </a>
 
           <a href="/User/profile"
   class="nav-link group relative flex items-center justify-center
          w-12 h-12 rounded-2xl
          text-teal-100/50
          hover:text-white hover:bg-teal-500/20 transition-all duration-300">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
    </svg>
    <span class="absolute left-16 scale-0 group-hover:scale-100 transition-all origin-left bg-slate-800 text-white text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest pointer-events-none shadow-xl z-50">Profile</span>
  </a>
    <div class="flex-1"></div>

    
  
             <a href="/User/logout"
   class="nav-link group relative flex items-center justify-center
          w-12 h-12 rounded-2xl
          text-teal-100/50
          hover:text-white hover:bg-teal-500/20 transition-all duration-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
      </svg>
      <span class="absolute left-16 scale-0 group-hover:scale-100 transition-all origin-left bg-rose-600 text-white text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest pointer-events-none shadow-xl z-50">Logout</span>
    </a>

  </aside>
  <script>
    const currentPath=window.location.pathname
    const navLinks=document.querySelectorAll('.nav-link')

    navLinks.forEach(link=>{
      if(link.getAttribute('href')===currentPath){
        link.classList.add('active-link')
      }
    })
  </script>
</body>
</html>  
