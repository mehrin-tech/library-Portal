<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Command Center</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --primary-teal: #2d8a78;
            --dark-teal: #004D4D;
            --sidebar-width: 80px;
        }
        .bg-dark-teal { background-color: var(--dark-teal); }
        .text-teal-accent { color: #2DD4BF; }
        
        /* Custom Tooltip Animation */
        .admin-tooltip {
            visibility: hidden;
            opacity: 0;
            transform: translateX(-10px);
            transition: all 0.3s ease;
        }
        .group:hover .admin-tooltip {
            visibility: visible;
            opacity: 1;
            transform: translateX(0);
        }
        .active-link{
          background-color:rgba(45, 212, 191, 0.25);
           color: white !important;
            box-shadow: 0 0 15px rgba(45, 212, 191, 0.4);
        }
    </style>
</head>
